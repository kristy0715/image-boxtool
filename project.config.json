{
  "description": "项目配置文件，详见文档：https://developers.weixin.qq.com/miniprogram/dev/devtools/projectconfig.html",
  "miniprogramRoot": "./",
  "srcMiniprogramRoot": "./",
  "cloudfunctionRoot": "cloudfunctions/",
  "packOptions": {
    "ignore": [
      {
        "type": "folder",
        "value": "cloudfunctions"
      }
    ],
    "include": []
