<view class="container" wx:if="{{isAllowed}}">
  
  <view class="page-header">
    <text class="page-title">AI 画质修复</text>
    <text class="page-subtitle">模糊变清晰 · 4倍无损放大</text>
  </view>

  <view class="content-area">
    <view class="upload-wrapper" wx:if="{{!selectedImage}}">
      
      <view class="hero-card">
        <view class="hero-demo-box">
          <view class="demo-half left">
             <text class="blur-effect">😐</text>
             <view class="demo-tag">Blur</view>
          </view>
          <view class="demo-slider-icon">↔</view>
          <view class="demo-half right">
             <text class="clear-effect">😎</text>
             <view class="demo-tag">HD</view>
          </view>
        </view>
        
        <view class="hero-bottom-row">
          <view class="hero-text-col">
            <text class="hero-h1">AI 智能画质重生</text>
            <text class="hero-p">老照片修复 / 表情包变高清</text>
          </view>
          <view class="feature-tags-hero">
            <view class="tag-item-hero">⚡ 极速</view>
            <view class="tag-item-hero">🔒 隐私</view>
          </view>
        </view>
      </view>

      <view class="action-card">
        <view class="upload-btn-area" bindtap="chooseImage">
          <view class="icon-box">💎</view>
          <text class="main-text">点击上传图片</text>
          <text class="sub-text">支持 JPG / PNG 格式</text>
        </view>

        <view class="cross-promote glow-effect" bindtap="goToWatermark">
          <view class="cp-icon">💡</view>
          <view class="cp-text">
            <text class="cp-title">照片有破损、霉斑或水印？</text>
            <text class="cp-desc">点我先用【AI 消除笔】无痕修补 >></text>
          </view>
        </view>
      </view>
    </view>

    <view class="preview-wrapper" wx:if="{{selectedImage && !resultImage}}">
      <view class="preview-box" style="width: 100%; display: flex; justify-content: center; background: #fff; padding: 20rpx; border-radius: 32rpx; box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.06); box-sizing: border-box;">
        <image src="{{selectedImage}}" mode="aspectFit" style="width: {{layout.width}}px; height: {{layout.height}}px; border-radius: 20rpx;"></image>
      </view>
      
      <view class="highlight-panel" style="margin-top: 30rpx; margin-bottom: 0;">
        <view class="settings-text-group">
          <text class="settings-title">✨ 加强人脸美颜修复</text>
          <text class="settings-desc">一键磨皮亮肤，提升五官立体感</text>
        </view>
        <switch checked="{{useBeauty}}" bindchange="toggleBeauty" color="#4f46e5"/>
      </view>

      <view class="cross-promote glow-effect" bindtap="goToWatermark" style="margin-top: 30rpx;">
        <view class="cp-icon">💡</view>
        <view class="cp-text">
          <text class="cp-title">照片有破损、霉斑或水印？</text>
          <text class="cp-desc">点我先用【AI 消除笔】无痕修补 >></text>
        </view>
      </view>
    </view>

    <view class="compare-wrapper" wx:if="{{resultImage}}">
      <view class="compare-card">
        <view class="compare-box" id="compareBox" 
              style="width: {{layout.width}}px; height: {{layout.height}}px;"
              bindtouchstart="onTouchStart" 
              catchtouchmove="onTouchMove" 
              catchtap="return">
          
          <image class="comp-img full" src="{{resultImage}}" mode="scaleToFill" style="width: {{layout.width}}px; height: {{layout.height}}px;"></image>
          
          <view class="comp-mask" style="{{ 'width:' + sliderValue + '%;' }}">
            <image class="comp-img clip" src="{{originImage}}" mode="scaleToFill" style="width: {{layout.width}}px; height: {{layout.height}}px;"></image>
            <view class="divider-line"></view>
          </view>

          <view class="status-tag left" style="{{ 'opacity:' + (sliderValue > 15 ? 1 : 0) + ';' }}">修复前</view>
          <view class="status-tag right" style="{{ 'opacity:' + (sliderValue < 85 ? 1 : 0) + ';' }}">修复后</view>
          <view class="touch-layer"></view>
        </view>
        <view class="instruction-bar"><text>↔️ 左右拖动查看对比效果</text></view>
      </view>
    </view>
  </view>

  <view class="ad-container" wx:if="{{bannerUnitId}}">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view style="height: 250rpx; width: 100%; display: block;"></view>

  <view class="bottom-bar" wx:if="{{selectedImage}}">
    <view class="action-row">
      <button class="btn-secondary" bindtap="chooseImage">重新选择</button>
      <button class="btn-primary" bindtap="startRestoration" wx:if="{{!resultImage}}">开始高清处理</button>
      <button class="btn-primary" bindtap="saveImage" wx:else>保存到相册</button>
    </view>
  </view>

  <view class="loading-overlay" wx:if="{{isProcessing}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText || 'AI 正在注入像素细节...'}}</text>
      <text style="font-size:24rpx; color:#94a3b8; margin-top:10rpx;">大概需要 5-15 秒</text>
    </view>
  </view>
</view>