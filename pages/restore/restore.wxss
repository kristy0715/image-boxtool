/* pages/restore/restore.wxss */

/* 🌟 核心修复：删除了干扰全局滑动的属性，保持最基础的底色和边距 */
page {
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

.container {
  padding: 0 30rpx;
}

/* === 视觉演示卡片 === */
.hero-card {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.3);
  position: relative; overflow: hidden;
  height: 360rpx; 
  display: flex; flex-direction: column;
  justify-content: space-between;
}
.hero-demo-box { flex: 1; display: flex; align-items: center; justify-content: center; position: relative; margin-bottom: 20rpx; }
.demo-half { width: 50%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.15); position: relative; overflow: hidden; }
.demo-half.left { border-top-left-radius: 16rpx; border-bottom-left-radius: 16rpx; border-right: 2rpx solid rgba(255,255,255,0.4); }
.demo-half.right { border-top-right-radius: 16rpx; border-bottom-right-radius: 16rpx; background: rgba(255,255,255,0.25); }
.blur-effect { font-size: 80rpx; opacity: 0.6; filter: blur(3px); }
.clear-effect { font-size: 80rpx; opacity: 1; filter: none; text-shadow: 0 4rpx 12rpx rgba(255,255,255,0.6); }
.demo-slider-icon { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 44rpx; height: 44rpx; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2); z-index: 5; }
.demo-tag { position: absolute; bottom: 10rpx; font-size: 20rpx; text-transform: uppercase; opacity: 0.9; font-weight: 700; }
.hero-text-row { display: flex; justify-content: space-between; align-items: center; }
.hero-h1 { font-size: 34rpx; font-weight: 700; }
.hero-p { font-size: 24rpx; opacity: 0.9; }

/* === 上传区域 === */
.upload-wrapper {
  background: #fff; border-radius: 32rpx; padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.action-card { padding: 0; background: transparent; box-shadow: none; margin-bottom: 0; }
.upload-btn-area {
  border: 4rpx dashed #a5b4fc; border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.03) 0%, rgba(236, 72, 153, 0.03) 100%);
  text-align: center; transition: all 0.3s ease;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 100%; min-height: 480rpx; 
}
.upload-btn-area:active { background: rgba(99, 102, 241, 0.08); border-color: #6366f1; transform: scale(0.99); }
.icon-box { font-size: 100rpx; margin-bottom: 30rpx; line-height: 1; }
.main-text { font-size: 36rpx; color: #475569; font-weight: 700; margin-bottom: 16rpx; }
.sub-text { font-size: 26rpx; color: #94a3b8; }
.feature-tags { display: flex; justify-content: center; gap: 24rpx; margin-top: 30rpx; }
.tag-item { font-size: 24rpx; color: #64748b; background: #f1f5f9; padding: 10rpx 24rpx; border-radius: 30rpx; font-weight: 500; }

/* === 跨页引流卡片 === */
.cross-promote {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border: 2rpx dashed #fbbf24;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(251, 191, 36, 0.15);
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}
.cross-promote:active { opacity: 0.8; transform: scale(0.98); }
.cp-icon { font-size: 50rpx; margin-right: 20rpx; line-height: 1; }
.cp-text { display: flex; flex-direction: column; flex: 1; }
.cp-title { font-size: 28rpx; font-weight: 800; color: #b45309; margin-bottom: 6rpx; }
.cp-desc { font-size: 24rpx; color: #d97706; font-weight: 500; }
.glow-effect { animation: pulseGlow 2s infinite; }
@keyframes pulseGlow {
  0% { box-shadow: 0 0 0 0 rgba(251, 191, 36, 0.4); }
  70% { box-shadow: 0 0 0 16rpx rgba(251, 191, 36, 0); }
  100% { box-shadow: 0 0 0 0 rgba(251, 191, 36, 0); }
}

/* === 对比查看区 === */
.compare-card { background: #fff; border-radius: 32rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); margin-bottom: 30rpx; padding: 0; display: flex; flex-direction: column; align-items: center; }
.compare-box { position: relative; overflow: hidden; background: #e2e8f0; touch-action: none; }
.comp-img { width: 100%; height: 100%; position: absolute; top: 0; left: 0; display: block; }
.comp-mask { position: absolute; top: 0; left: 0; height: 100%; z-index: 10; overflow: hidden; border-right: 3rpx solid #fff; background: transparent; will-change: width; }
.comp-mask .comp-img.clip { max-width: none; display: block; }
.divider-line { position: absolute; right: -24rpx; top: 50%; width: 48rpx; height: 48rpx; background: #fff; border-radius: 50%; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; transform: translateY(-50%); z-index: 20; }
.divider-line::after { content: ''; width: 4rpx; height: 24rpx; background: #94a3b8; border-radius: 2rpx; margin: 0 2rpx; box-shadow: 6rpx 0 0 #94a3b8; }
.status-tag { position: absolute; bottom: 30rpx; z-index: 15; background: rgba(0,0,0,0.6); color: #fff; font-size: 26rpx; padding: 10rpx 24rpx; border-radius: 12rpx; backdrop-filter: blur(4px); pointer-events: none; font-weight: 500; border: 1rpx solid rgba(255,255,255,0.2); }
.status-tag.left { left: 20rpx; }
.status-tag.right { right: 20rpx; }
.touch-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 50; }
.instruction-bar { width: 100%; text-align: center; font-size: 26rpx; color: #64748b; padding: 24rpx; background: #fff; border-top: 1rpx solid #f1f5f9; }

/* === 广告与底部栏 === */
.ad-container { width: 100%; box-sizing: border-box; margin-top: 20rpx; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.95); backdrop-filter: blur(20rpx);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); display: flex; gap: 24rpx; z-index: 100;
}
.circle-btn { width: 96rpx; height: 96rpx; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #475569; }
.save-btn { flex: 1; height: 96rpx; background: #6366f1; color: #fff; border-radius: 48rpx; font-size: 32rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; margin: 0 !important; box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.3); }

/* === 加载弹窗 === */
.loading-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); backdrop-filter: blur(8px); z-index: 999; display: flex; align-items: center; justify-content: center; }
.loading-box { background: rgba(0,0,0,0.8); padding: 50rpx 60rpx; border-radius: 32rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.15); }
.loading-spinner { width: 80rpx; height: 80rpx; border: 6rpx solid rgba(255,255,255,0.2); border-top-color: #fff; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 30rpx; }
.loading-text { color: #fff; font-size: 28rpx; font-weight: 500; letter-spacing: 2rpx; }
@keyframes spin { to { transform: rotate(360deg); } }