/* pages/restore/restore.wxss */
page {
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

.container {
  padding: 0 30rpx;
}

/* 🚨 已经彻底删除 .page-header / .page-title 的强行覆写代码 */
/* 现在的标题将 100% 继承你的全局 app.wxss，与其他模块完美对齐且不换行！ */

/* === 🌟 压缩版视觉演示卡片 (保留空间优化) === */
.hero-card {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 32rpx;
  padding: 30rpx;
  color: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(99, 102, 241, 0.25);
  position: relative; overflow: hidden;
  height: 260rpx; 
  display: flex; flex-direction: column;
  justify-content: space-between;
}
.hero-demo-box { flex: 1; display: flex; align-items: center; justify-content: center; position: relative; margin-bottom: 16rpx; }
.demo-half { width: 50%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.15); position: relative; overflow: hidden; }
.demo-half.left { border-top-left-radius: 16rpx; border-bottom-left-radius: 16rpx; border-right: 2rpx solid rgba(255,255,255,0.4); }
.demo-half.right { border-top-right-radius: 16rpx; border-bottom-right-radius: 16rpx; background: rgba(255,255,255,0.25); }
.blur-effect { font-size: 64rpx; opacity: 0.6; filter: blur(3px); } 
.clear-effect { font-size: 64rpx; opacity: 1; filter: none; text-shadow: 0 4rpx 12rpx rgba(255,255,255,0.6); }
.demo-slider-icon { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 40rpx; height: 40rpx; background: #fff; color: #6366f1; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; font-weight: bold; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2); z-index: 5; }
.demo-tag { position: absolute; bottom: 8rpx; font-size: 18rpx; text-transform: uppercase; opacity: 0.9; font-weight: 700; }

.hero-bottom-row { display: flex; justify-content: space-between; align-items: flex-end; }
.hero-text-col { display: flex; flex-direction: column; }
.hero-h1 { font-size: 32rpx; font-weight: 700; margin-bottom: 4rpx; }
.hero-p { font-size: 22rpx; opacity: 0.9; }

/* 上移的安全标签样式 */
.feature-tags-hero { display: flex; gap: 12rpx; margin-bottom: 4rpx; }
.tag-item-hero { font-size: 20rpx; color: #fff; background: rgba(255,255,255,0.2); padding: 6rpx 16rpx; border-radius: 100rpx; font-weight: 500; backdrop-filter: blur(8px); border: 1rpx solid rgba(255,255,255,0.3); }

/* === 压缩版上传操作区 === */
.upload-wrapper { background: transparent; padding: 0; box-shadow: none; }
.action-card { padding: 0; background: transparent; margin-bottom: 0; }
.upload-btn-area {
  border: 4rpx dashed #a5b4fc; border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.03) 0%, rgba(236, 72, 153, 0.03) 100%);
  text-align: center; transition: all 0.3s ease;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 100%; min-height: 320rpx; 
  background-color: #fff;
}
.upload-btn-area:active { background: rgba(99, 102, 241, 0.08); border-color: #6366f1; transform: scale(0.99); }
.icon-box { font-size: 80rpx; margin-bottom: 12rpx; line-height: 1; }
.main-text { font-size: 32rpx; color: #475569; font-weight: 700; margin-bottom: 8rpx; }
.sub-text { font-size: 24rpx; color: #94a3b8; }

/* 🌟 重磅回归：高强度全局呼吸灯闪烁特效 */
.cross-promote {
  margin-top: 24rpx; 
  display: flex;
  align-items: center; padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border: 2rpx dashed #fbbf24;
  border-radius: 20rpx; box-shadow: 0 8rpx 20rpx rgba(251, 191, 36, 0.15);
  transition: all 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}
.cross-promote:active { opacity: 0.8; transform: scale(0.98); }
.cp-icon { font-size: 44rpx; margin-right: 16rpx; line-height: 1; }
.cp-text { display: flex; flex-direction: column; flex: 1; }
.cp-title { font-size: 26rpx; font-weight: 800; color: #b45309; margin-bottom: 4rpx; }
.cp-desc { font-size: 22rpx; color: #d97706; font-weight: 500; }

/* 让整个区域变色、放大、带阴影的强力呼吸灯 */
.glow-effect { animation: breathingLight 1.8s infinite ease-in-out; }
@keyframes breathingLight {
  0% { box-shadow: 0 4rpx 10rpx rgba(251, 191, 36, 0.2); opacity: 1; transform: scale(1); }
  50% { box-shadow: 0 12rpx 32rpx rgba(251, 191, 36, 0.7); opacity: 0.65; transform: scale(1.015); background: #fde68a; border-color: #f59e0b; }
  100% { box-shadow: 0 4rpx 10rpx rgba(251, 191, 36, 0.2); opacity: 1; transform: scale(1); }
}

/* === 核心对比区 === */
.compare-card { background: #fff; border-radius: 32rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); margin-bottom: 30rpx; padding: 0; display: flex; flex-direction: column; align-items: center; }
.compare-box { position: relative; overflow: hidden; background: #e2e8f0; touch-action: none; }
.comp-img { position: absolute; top: 0; left: 0; display: block; }
.comp-img.full { z-index: 1; }
.comp-mask { position: absolute; top: 0; left: 0; height: 100%; z-index: 10; overflow: hidden; border-right: 3rpx solid #fff; background: transparent; will-change: width; }
.comp-mask .comp-img.clip { max-width: none; display: block; }
.divider-line { position: absolute; right: -24rpx; top: 50%; width: 48rpx; height: 48rpx; background: #fff; border-radius: 50%; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; transform: translateY(-50%); z-index: 20; }
.divider-line::after { content: ''; width: 4rpx; height: 24rpx; background: #94a3b8; border-radius: 2rpx; margin: 0 2rpx; box-shadow: 6rpx 0 0 #94a3b8; }
.status-tag { position: absolute; bottom: 30rpx; z-index: 15; background: rgba(0,0,0,0.6); color: #fff; font-size: 26rpx; padding: 10rpx 24rpx; border-radius: 12rpx; backdrop-filter: blur(4px); pointer-events: none; font-weight: 500; border: 1rpx solid rgba(255,255,255,0.2); }
.status-tag.left { left: 20rpx; }
.status-tag.right { right: 20rpx; }
.touch-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 50; }
.instruction-bar { width: 100%; text-align: center; font-size: 26rpx; color: #64748b; padding: 24rpx; background: #fff; border-top: 1rpx solid #f1f5f9; }

.ad-container { width: 100%; box-sizing: border-box; margin-top: 20rpx; margin-bottom: 20rpx; }

/* 底部栏 */
.bottom-bar { 
  position: fixed; bottom: 0; left: 0; right: 0; 
  background: rgba(255,255,255,0.95); backdrop-filter: blur(20rpx); padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); z-index: 100;
}
.action-row { display: flex; gap: 24rpx; }
.btn-secondary, .btn-primary {
  margin: 0; border: none; font-size: 32rpx; font-weight: 600;
  height: 96rpx; line-height: 96rpx; border-radius: 100rpx;
  display: flex; align-items: center; justify-content: center;
}
.btn-secondary::after, .btn-primary::after { display: none; }
.btn-secondary { flex: 1; background: #f1f5f9; color: #475569; }
.btn-primary { flex: 2.2; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #ffffff; box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.25); }

/* 加载弹窗 */
.loading-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); backdrop-filter: blur(8px); z-index: 999; display: flex; align-items: center; justify-content: center; }
.loading-box { background: rgba(0,0,0,0.8); padding: 50rpx 60rpx; border-radius: 32rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.15); }
.loading-spinner { width: 80rpx; height: 80rpx; border: 6rpx solid rgba(255,255,255,0.2); border-top-color: #fff; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 30rpx; }
.loading-text { color: #fff; font-size: 28rpx; font-weight: 500; letter-spacing: 2rpx; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ================= 🌟 新增：美颜开关高亮面板样式 ================= */
.highlight-panel {
  background: linear-gradient(135deg, #f0fdf4 0%, #e0e7ff 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.08);
  border: 2rpx solid #ffffff;
  box-sizing: border-box;
  width: 100%;
}
.settings-text-group { display: flex; flex-direction: column; }
.settings-title { font-size: 30rpx; font-weight: 800; color: #3730a3; margin-bottom: 6rpx; }
.settings-desc { font-size: 22rpx; color: #4f46e5; opacity: 0.85; }