page { background-color: #F7F8FA; font-family: -apple-system, sans-serif; }
.container { padding: 32rpx; padding-bottom: calc(60rpx + env(safe-area-inset-bottom)); }

.asset-card { background: linear-gradient(135deg, #2A2D3E 0%, #1A1C29 100%); border-radius: 32rpx; padding: 40rpx; color: #FFFFFF; box-shadow: 0 16rpx 40rpx rgba(26, 28, 41, 0.15); margin-bottom: 48rpx; position: relative; overflow: hidden; }
.asset-card::after { content: ''; position: absolute; top: -50%; right: -20%; width: 300rpx; height: 300rpx; background: radial-gradient(circle, rgba(99,102,241,0.3) 0%, rgba(0,0,0,0) 70%); border-radius: 50%; }

.asset-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; position: relative; z-index: 2; }
.asset-title { font-size: 26rpx; color: rgba(255, 255, 255, 0.7); }
.record-btn { font-size: 24rpx; color: rgba(255, 255, 255, 0.5); padding: 10rpx 0; }
.record-btn:active { opacity: 0.7; }
.asset-body { display: flex; align-items: baseline; margin-bottom: 30rpx; position: relative; z-index: 2; }
.points-num { font-size: 88rpx; font-weight: bold; font-family: 'DIN Alternate', sans-serif; line-height: 1; text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3); }
.points-unit { font-size: 28rpx; margin-left: 12rpx; color: rgba(255,255,255,0.8); }
.asset-footer { border-top: 1rpx solid rgba(255,255,255,0.1); padding-top: 24rpx; font-size: 22rpx; color: rgba(255, 255, 255, 0.5); position: relative; z-index: 2; }

.section-title { font-size: 34rpx; font-weight: bold; color: #1D2129; margin-bottom: 32rpx; }
.goods-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24rpx; }
.goods-card { background: #FFFFFF; border-radius: 24rpx; padding: 32rpx 24rpx; box-shadow: 0 4rpx 20rpx rgba(149, 157, 165, 0.05); position: relative; display: flex; flex-direction: column; transition: transform 0.1s; }
.goods-card:active { transform: scale(0.98); background: #FCFCFD; }

.badge { position: absolute; top: 0; left: 0; padding: 6rpx 16rpx; border-radius: 24rpx 0 24rpx 0; font-size: 20rpx; font-weight: bold; color: #FFF; z-index: 2; }
.badge.hot { background: linear-gradient(90deg, #FF6B6B 0%, #FF4757 100%); }
.badge.new { background: linear-gradient(90deg, #10B981 0%, #059669 100%); }
.badge.discount { background: linear-gradient(90deg, #F59E0B 0%, #D97706 100%); }

.goods-icon { font-size: 72rpx; text-align: center; margin: 20rpx 0 16rpx 0; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1)); }
.goods-name { font-size: 28rpx; font-weight: bold; color: #1D2129; text-align: center; margin-bottom: 8rpx; }
.goods-desc { font-size: 20rpx; color: #86909C; text-align: center; margin-bottom: 30rpx; line-height: 1.4; padding: 0 10rpx; }

.goods-bottom { margin-top: auto; display: flex; flex-direction: column; align-items: center; }
.price-details { display: flex; flex-direction: column; align-items: center; gap: 8rpx; margin-bottom: 24rpx; }

.current-row { display: flex; align-items: baseline; }
.price-num { font-size: 44rpx; font-weight: bold; color: #4F46E5; font-family: 'DIN Alternate', sans-serif; line-height: 1; }
.price-unit { font-size: 20rpx; color: #4F46E5; margin-left: 6rpx; font-weight: bold; }

.original-row { display: flex; align-items: center; gap: 10rpx; }
.original-num { font-size: 20rpx; color: #C9CDD4; text-decoration: line-through; }
.discount-tag { font-size: 18rpx; color: #4F46E5; border: 1rpx solid #4F46E5; padding: 2rpx 8rpx; border-radius: 6rpx; font-weight: 500; }

.buy-btn { width: 100%; text-align: center; padding: 16rpx 0; border-radius: 40rpx; font-size: 26rpx; font-weight: bold; transition: all 0.2s; }
.buy-btn.active { background: linear-gradient(90deg, #6366f1 0%, #4f46e5 100%); color: #FFFFFF; box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.25); }
.buy-btn.active:active { transform: scale(0.96); opacity: 0.9; }
.buy-btn.disabled { background: #F2F3F5; color: #C9CDD4; }

.bottom-tips { text-align: center; margin-top: 60rpx; font-size: 22rpx; color: #C9CDD4; }

.goods-icon-img { width: 160rpx; height: 160rpx; margin: 10rpx auto 20rpx; display: block; }

/* 🌟 新增：广告容器样式 */
.ad-box { 
  margin-top: 40rpx; 
  border-radius: 16rpx; 
  overflow: hidden; 
  box-shadow: 0 4rpx 20rpx rgba(149, 157, 165, 0.06);
}

/* ================= 🌟 新增：温馨提示公告栏 ================= */
.notice-box {
  display: flex;
  align-items: flex-start;
  background: #EEF2FF; /* 极浅的紫蓝色背景 */
  border: 2rpx solid #C7D2FE; /* 柔和的边框 */
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 40rpx; /* 与下方的商品列表拉开间距 */
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.05);
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  line-height: 1.4;
}

.notice-text {
  font-size: 24rpx;
  color: #4F46E5; /* 主题深紫色文字 */
  line-height: 1.5;
  flex: 1;
  text-align: justify;
}