page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
}
.page-bg { padding: 30rpx 0; min-height: 100vh; }
.container { padding: 0 30rpx; }

/* ================= 核心阴影配置 ================= */
.shadow-card { box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.06) !important; }
.shadow-btn { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08) !important; }
.shadow-btn-blue { box-shadow: 0 8rpx 24rpx rgba(43, 102, 255, 0.3) !important; }

.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.card-title { font-size: 36rpx; font-weight: bold; color: #333333; margin-bottom: 12rpx; }
.card-desc { font-size: 26rpx; color: #888888; margin-bottom: 30rpx; }

.url-input {
  width: 100%;
  height: 180rpx;
  background: #F8F9FB;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 30rpx;
}

.btn-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}
.btn {
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  transition: 0.2s;
  box-sizing: border-box; 
}
.btn text {
  margin-right: 6rpx;
  font-size: 30rpx;
}
.btn:active { transform: scale(0.96); opacity: 0.9; }

.clear-btn { width: 140rpx; background: #F2F4F8; color: #555555; border: 1px solid #E4E7ED; }
.paste-btn { width: 140rpx; background: #E4EDFF; color: #2B66FF; border: 1px solid #B0C9FF; }

.parse-btn { flex: 1; background: linear-gradient(90deg, #4A90E2, #2B66FF); color: #FFFFFF; border: none; }
.parse-btn.loading { opacity: 0.7; pointer-events: none; }

.guide-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 30rpx; display: flex; align-items: center; }
.guide-title::before { content: ''; display: inline-block; width: 8rpx; height: 30rpx; background: #2B66FF; border-radius: 4rpx; margin-right: 16rpx; }
.guide-step { display: flex; align-items: flex-start; margin-bottom: 26rpx; }
.guide-step:last-child { margin-bottom: 0; }
.step-num { flex-shrink: 0; width: 40rpx; height: 40rpx; background: #E8F0FF; color: #2B66FF; font-size: 24rpx; font-weight: bold; display: flex; justify-content: center; align-items: center; border-radius: 50%; margin-right: 20rpx; margin-top: 4rpx; }
.step-text { font-size: 28rpx; color: #666666; line-height: 1.6; flex: 1; }

.ad-wrap { border-radius: 20rpx; overflow: hidden; padding: 0; background: transparent; }
.ad-wrap ad { display: block; width: 100%; border-radius: 20rpx; }

.result-card { padding-top: 40rpx; }
.success-badge { display: inline-block; font-size: 24rpx; font-weight: bold; color: #2B66FF; background: #E8F0FF; padding: 8rpx 24rpx; border-radius: 8rpx; margin-bottom: 30rpx; }

.media-box { width: 100%; border-radius: 12rpx; overflow: hidden; background: #F8F9FB; margin-bottom: 30rpx; border: 1px solid #EEEEEE; }
.result-video { width: 100%; height: 400rpx; display: block; background: #000; }

.img-scroll { 
  width: 100%; 
  height: auto; 
  white-space: nowrap; 
  padding: 24rpx 24rpx 10rpx 24rpx; 
  box-sizing: border-box; 
}
.img-item-wrap { 
  width: 260rpx; 
  display: inline-block; 
  vertical-align: top;
  margin-right: 20rpx; 
}
.img-item-wrap:last-child { margin-right: 0; }
.res-img { width: 100%; height: 340rpx; border-radius: 12rpx; display: block; background: #E5E5EA; margin-bottom: 16rpx; }
.img-tools { display: flex; justify-content: space-between; gap: 12rpx; }

.img-tool-btn { flex: 1; background: #FFFFFF; color: #333333; font-size: 24rpx; font-weight: bold; padding: 12rpx 0; text-align: center; border-radius: 8rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); border: 1px solid #E4E7ED; box-sizing: border-box; }
.img-tool-btn.download { background: #E4EDFF; color: #2B66FF; border: 1px solid #B0C9FF; }

.scroll-hint {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 24rpx 0;
  font-size: 24rpx;
  color: #999999;
  background: #F8F9FB;
  border-top: 1px dashed #E4E7ED;
}
.hint-icon { font-size: 20rpx; margin: 0 10rpx; color: #2B66FF; }

.desc-box { background: #F8F9FB; padding: 24rpx; border-radius: 12rpx; margin-bottom: 40rpx; border: 1px solid #EEEEEE; }
.desc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.desc-title { font-size: 28rpx; font-weight: bold; color: #333333; }
.copy-btn { font-size: 24rpx; color: #333333; background: #FFFFFF; padding: 10rpx 30rpx; border-radius: 100rpx; font-weight: 500; border: 1px solid #DCDFE6; }
.desc-text { font-size: 28rpx; color: #555555; line-height: 1.6; word-break: break-all; }

/* ================= 🌟 修复：复制与下载按钮水平一行 ================= */
.bottom-btns { 
  display: flex !important; 
  flex-direction: row !important;      /* 强制横向水平排列 */
  justify-content: space-between;      /* 两端平分对齐 */
  align-items: center;
  gap: 30rpx; 
  width: 100%;
  box-sizing: border-box;
  margin-top: 20rpx;                   /* 和上方描述框稍微拉开一点距离 */
}

.b-btn { 
  flex: 1 !important;                  /* 1:1 绝对平分空间 */
  width: 100% !important;              /* 压制微信 button 原生宽度设定 */
  height: 88rpx; 
  border-radius: 100rpx; 
  font-size: 30rpx; 
  font-weight: bold; 
  display: flex; 
  justify-content: center; 
  align-items: center; 
  margin: 0 !important;                /* 彻底干掉微信自带的边距干扰 */
  border: none; 
  box-sizing: border-box; 
}
.b-btn::after { display: none; }
.b-btn.outline { background: #F2F4F8; color: #333333; border: 1px solid #DCDFE6; }
.b-btn.primary { background: #2B66FF; color: #FFFFFF; }

/* ================= 🌟 修复：防 TabBar 遮挡 ================= */
.bottom-spacer { 
  height: 180rpx !important;           /* 加高到 180rpx 避开菜单栏 */
  padding-bottom: env(safe-area-inset-bottom); 
  width: 100%; 
}

.top-tips { position: fixed; top: 0; left: 0; right: 0; background: rgba(0,0,0,0.8); z-index: 99999; display: flex; justify-content: center; padding: 24rpx 0; transform: translateY(-100%); transition: 0.3s; }
.top-tips.show { transform: translateY(0); }

/* ================= 🌟 新增：本地图片去水印横幅样式 ================= */
.local-tools-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(90deg, #E8F0FF, #D1E0FF);
  padding: 36rpx 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  border: 1px solid #B0C9FF;
  transition: 0.2s;
  box-sizing: border-box;
}
.local-tools-banner:active { 
  transform: scale(0.98); 
  opacity: 0.9; 
}
.banner-left { 
  display: flex; 
  align-items: center; 
}
.banner-icon { 
  font-size: 40rpx; 
  margin-right: 20rpx; 
}
.banner-text { 
  font-size: 30rpx; 
  font-weight: bold; 
  color: #2B66FF; 
}
.banner-right { 
  font-size: 26rpx; 
  color: #2B66FF; 
  font-weight: bold; 
  opacity: 0.8; 
}

/* ================= 🌟 新增：温馨提示样式 ================= */
.retry-hint {
  display: flex;
  align-items: flex-start;
  margin-top: 30rpx;
  padding: 20rpx 24rpx;
  background: #F8F9FB;
  border-radius: 12rpx;
  border: 1px dashed #DCDFE6;
}
.hint-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  margin-top: 2rpx;
}
.hint-text {
  font-size: 24rpx;
  color: #86909C;
  line-height: 1.5;
  flex: 1;
}
.retry-hint .highlight {
  color: #2B66FF;
  font-weight: bold;
  margin: 0 4rpx;
}