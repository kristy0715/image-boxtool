<view class="page-bg">
  <top-tips id="topTips"></top-tips>

  <view class="container">
    
    <view class="card shadow-card">
      <view class="card-title">全网无水印提取</view>
      <view class="card-desc">支持主流平台图片、图集、实况、视频 无水印提取</view>
      
      <textarea 
        class="url-input" 
        placeholder="请复制分享口令或链接，粘贴到这里" 
        value="{{inputValue}}"
        bindinput="handleInput"
        maxlength="-1"
      ></textarea>

      <view class="btn-row">
        <view class="btn clear-btn shadow-btn" bindtap="clearInput">
          <text>🗑️</text>清空
        </view>
        <view class="btn paste-btn shadow-btn" bindtap="pasteFromClipboard">
          <text>📋</text>粘贴
        </view>
        <view class="btn parse-btn shadow-btn-blue {{isProcessing ? 'loading' : ''}}" bindtap="startParse">
          {{isProcessing ? '正在解析...' : '开始解析'}}
        </view>
      </view>
    </view>

    <view class="card shadow-card" wx:if="{{!videoData}}">
      <view class="guide-title">使用指南</view>
      <view class="guide-step">
        <text class="step-num">1</text>
        <text class="step-text">打开APP，找到想要去水印的内容</text>
      </view>
      <view class="guide-step">
        <text class="step-num">2</text>
        <text class="step-text">点击分享按钮，选择“复制链接”</text>
      </view>
      <view class="guide-step">
        <text class="step-num">3</text>
        <text class="step-text">将链接粘贴到上方，点击开始解析</text>
      </view>
      <view class="retry-hint" style="margin-top: 0rpx;">
        <text class="hint-icon">💡</text>
        <view class="hint-text">如下载失败，请尝试<text class="highlight">多点几次解析</text>或更换链接。</view>
      </view>
    </view>

    <view id="resultArea" class="card shadow-card result-card" wx:if="{{videoData}}">
      <view class="success-badge">✨ 解析成功</view>

      <view class="media-box" wx:if="{{videoData.type === 'video'}}">
        <video class="result-video" src="{{videoData.url}}" poster="{{videoData.cover}}" controls></video>
      </view>
      
      <view class="media-box" wx:if="{{videoData.type === 'images'}}">
        <scroll-view class="img-scroll" scroll-x="true">
          <view class="img-item-wrap" wx:for="{{videoData.images}}" wx:key="index">
            <image class="res-img" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"></image>
            <view class="img-tools">
              <view class="img-tool-btn download" style="width: 100%; text-align: center; border-right: none;" catchtap="saveSingleImage" data-url="{{item}}">⬇️ 存入相册</view>
            </view>
          </view>
        </scroll-view>
        <view class="scroll-hint" wx:if="{{videoData.images.length > 2}}">
          <text class="hint-icon">👈</text>
          <text>左右滑动查看剩余图片 (共{{videoData.images.length}}张)</text>
          <text class="hint-icon">👉</text>
        </view>
      </view>

      <view class="desc-box">
        <view class="desc-top">
          <text class="desc-title">提取文案</text>
          <view class="copy-btn shadow-btn" bindtap="copyTitle">复制</view>
        </view>
        <text class="desc-text" selectable="true">{{videoData.title}}</text>
      </view>

      <view class="bottom-btns">
        <button class="b-btn primary shadow-btn" style="width: 100%;" bindtap="saveResource">
          {{videoData.type === 'images' ? '📥 一键下载全部' : '📥 ' + downloadProgressText}}
        </button>
      </view>
    </view>

    <view class="local-tools-banner shadow-card" bindtap="goToLocalWatermark">
      <view class="banner-left">
        <text class="banner-icon">🖌️</text>
        <text class="banner-text">本地图片去水印 (消除笔)</text>
      </view>
      <view class="banner-right">去体验 ></view>
    </view>

    <view class="ad-wrap shadow-card" wx:if="{{bannerUnitId}}">
      <ad unit-id="{{bannerUnitId}}"></ad>
    </view>

    <view class="bottom-spacer"></view>

  </view>
</view>