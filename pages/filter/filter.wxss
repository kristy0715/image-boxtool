/* pages/filter/filter.wxss */
page {
  background-color: #f7f8fa;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.preview-card {
  padding: 0;
  overflow: hidden;
}

.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.preview-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  background: #f1f5f9;
  min-height: 400rpx;
}

.preview-canvas {
  max-width: 100%;
  border-radius: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 滤镜选择 */
.filter-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.filter-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.filter-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.filter-thumb-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  border: 4rpx solid transparent;
}

.filter-item.active .filter-thumb-wrapper {
  border-color: #6366f1;
}

.filter-thumb {
  width: 100%;
  height: 100%;
}

.filter-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.filter-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.filter-item.active .filter-name {
  color: #6366f1;
  font-weight: 600;
}

/* 调节滑块 */
.slider-item {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.slider-item:last-child {
  margin-bottom: 0;
}

.slider-label {
  width: 120rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.slider {
  flex: 1;
  margin: 0 20rpx;
}

.slider-value {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-light);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0;
  left: 0; right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx;
  z-index: 100;
}

.btn-secondary {
  flex: 1; background: #f1f5f9;
  color: #333;
  font-size: 30rpx; border-radius: 44rpx;
  margin: 0; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}

.btn-primary {
  flex: 2; background: #6366f1; color: #fff;
  font-size: 32rpx; font-weight: 600; border-radius: 44rpx;
  margin: 0; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}