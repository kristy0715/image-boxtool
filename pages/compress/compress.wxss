/* pages/compress/compress.wxss */

.upload-icon-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* 图片预览 */
.image-preview {
  text-align: center;
}

.preview-img {
  width: 100%;
  max-height: 400rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.image-info {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-value.highlight {
  color: var(--primary-color);
}

.info-value.success {
  color: #10b981;
}

.change-btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #f1f5f9;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.section-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 滑块区域 */
.slider-section, .size-section {
  margin-bottom: 32rpx;
}

/* 模式选项 */
.mode-options {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.mode-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.mode-item.active {
  background: rgba(99, 102, 241, 0.1);
  border-color: #6366f1;
}

.mode-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.mode-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.mode-item.active .mode-name {
  color: #6366f1;
  font-weight: 600;
}

.slider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.slider-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.slider-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.custom-slider {
  margin: 0;
}

.slider-tips {
  margin-top: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 快捷选项 */
.quick-options {
  display: flex;
  gap: 16rpx;
}

.quick-item {
  flex: 1;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: var(--radius-md);
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.quick-item.active {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-color: var(--primary-color);
}

.quick-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.quick-item.active .quick-label {
  color: var(--primary-color);
}

.quick-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
}

/* 结果卡片 */
.result-card {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(99, 102, 241, 0.05) 100%);
}

.result-preview {
  margin-bottom: 24rpx;
}

.result-img {
  width: 100%;
  max-height: 300rpx;
  border-radius: var(--radius-md);
}

.result-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: var(--radius-md);
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stat-value.highlight {
  color: #10b981;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.stat-arrow {
  font-size: 36rpx;
  color: var(--primary-color);
}
