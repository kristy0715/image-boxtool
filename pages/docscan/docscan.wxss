page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
}
.page-bg { padding: 30rpx 0; min-height: 100vh; }
.container { padding: 0 30rpx; }

/* 核心阴影配置 (严格对齐你的其它页面) */
.shadow-card { box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.06) !important; background: #FFFFFF; border-radius: 20rpx; margin-bottom: 30rpx; padding: 40rpx 30rpx; }
.shadow-btn { box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08) !important; }
.shadow-btn-blue { box-shadow: 0 8rpx 24rpx rgba(43, 102, 255, 0.3) !important; }

.header { margin-bottom: 30rpx; padding: 0 10rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #333333; margin-bottom: 12rpx; }
.desc { font-size: 26rpx; color: #888888; }

.upload-area {
  height: 400rpx;
  background: #F8F9FB;
  border: 3rpx dashed #C2D3FF;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: 0.2s;
}
.upload-area:active { background: #E4EDFF; border-color: #2B66FF; }
.icon { font-size: 80rpx; margin-bottom: 20rpx; }
.text { font-size: 30rpx; color: #2B66FF; font-weight: bold; }

.preview-img {
  width: 100%;
  height: 600rpx;
  background: #F8F9FB;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  border: 1px solid #EEEEEE;
}

.action-row { display: flex; gap: 20rpx; }
.btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  transition: 0.2s;
  box-sizing: border-box;
}
.btn:active { transform: scale(0.96); opacity: 0.9; }

.re-upload { background: #F2F4F8; color: #555555; border: 1px solid #E4E7ED; }
.process-btn { background: linear-gradient(90deg, #4A90E2, #2B66FF); color: #FFFFFF; border: none; }
.process-btn.loading { opacity: 0.7; pointer-events: none; }

.outline-btn { background: #FFFFFF; color: #333333; border: 1px solid #DCDFE6; }
.primary-btn { background: #2B66FF; color: #FFFFFF; border: none; }

.guide-title { font-size: 30rpx; font-weight: bold; margin-bottom: 24rpx; color: #333333; display: flex; align-items: center; }
.guide-title::before { content: ''; width: 8rpx; height: 30rpx; background: #2B66FF; border-radius: 4rpx; margin-right: 16rpx; }
.guide-step { font-size: 26rpx; color: #666666; margin-bottom: 16rpx; display: flex; line-height: 1.6; }
.guide-step text { font-weight: bold; color: #2B66FF; margin-right: 12rpx; background: #E4EDFF; width: 32rpx; height: 32rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 20rpx; margin-top: 4rpx;}

.ad-wrap { padding: 0; overflow: hidden; }
.ad-wrap ad { display: block; width: 100%; border-radius: 20rpx; }
.bottom-spacer { height: 80rpx; padding-bottom: env(safe-area-inset-bottom); width: 100%; }