<view class="page-bg">
  <view class="container">
    
    <view class="header">
      <view class="title">一键试卷去手写</view>
      <view class="desc">智能擦除做题痕迹，还原空白试卷方便二次练习</view>
    </view>

    <view class="upload-card shadow-card" wx:if="{{!originalImage}}">
      <view class="upload-area" bindtap="chooseImage">
        <text class="icon">📄</text>
        <text class="text">拍试卷 / 选相册</text>
      </view>
    </view>

    <view class="preview-card shadow-card" wx:else>
      <image class="preview-img" src="{{resultImage || originalImage}}" mode="aspectFit" bindtap="previewImage"></image>

      <view class="action-row" wx:if="{{!resultImage}}">
        <view class="btn re-upload shadow-btn" bindtap="chooseImage">重新选择</view>
        <view class="btn process-btn shadow-btn-blue {{isProcessing ? 'loading' : ''}}" bindtap="startProcess">
          {{isProcessing ? '正在擦除字迹...' : '一键去手写'}}
        </view>
      </view>

      <view class="action-row" wx:if="{{resultImage}}">
        <view class="btn outline-btn shadow-btn" bindtap="chooseImage">处理下一张</view>
        <view class="btn primary-btn shadow-btn-blue" bindtap="saveImage">保存到手机</view>
      </view>
    </view>

    <view class="guide-card shadow-card" wx:if="{{!originalImage}}">
      <view class="guide-title">使用提示</view>
      <view class="guide-step"><text>1.</text> 尽量在光线充足、无严重阴影的环境下拍摄。</view>
      <view class="guide-step"><text>2.</text> 保持试卷平整，俯视拍摄，将试卷铺满整个画面。</view>
      <view class="guide-step"><text>3.</text> 自动识别并擦除手写笔迹，保留印刷原题。</view>
    </view>

    <view class="ad-wrap shadow-card" wx:if="{{bannerUnitId}}">
      <ad unit-id="{{bannerUnitId}}"></ad>
    </view>
    
    <view class="bottom-spacer"></view>

  </view>
</view>