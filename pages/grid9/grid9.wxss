/* pages/grid9/grid9.wxss */

.preview-card {
  padding: 0;
  overflow: hidden;
}

.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  /* 【关键】修复图标垂直对齐 */
  line-height: 1; 
}

.upload-text {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.preview-wrapper {
  padding: 40rpx 20rpx;
  background: #f1f5f9;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 预览框样式优化 */
.grid-preview {
  position: relative;
  width: 500rpx; /* 使用 rpx 适配不同屏幕 */
  height: 500rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 4rpx;
  display: block;
}

.grid-lines {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  border: 2rpx solid rgba(255,255,255,0.8); /* 外边框 */
}

.h-line {
  position: absolute;
  left: 0; right: 0;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 4rpx rgba(0, 0, 0, 0.3);
}

.v-line {
  position: absolute;
  top: 0; bottom: 0;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 4rpx rgba(0, 0, 0, 0.3);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 切割结果展示 */
.grid-result {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 10rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

/* 4宫格特殊样式 */
.grid-result.grid-4 {
  grid-template-columns: repeat(2, 1fr);
  width: 66.66%; /* 视觉上缩小一点，不用撑满 */
  margin: 0 auto;
}

.grid-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  display: block;
}

.grid-tip {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #6366f1;
  text-align: center;
  background: rgba(99, 102, 241, 0.08);
  padding: 12rpx;
  border-radius: 8rpx;
}

/* 切割选项 */
.cut-options {
  display: flex;
  gap: 24rpx;
}

.cut-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.cut-item.active {
  background: rgba(99, 102, 241, 0.08);
  border-color: #6366f1;
}

.cut-icon {
  display: grid;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.cut-icon.grid-9 {
  grid-template-columns: repeat(3, 1fr);
  width: 66rpx;
  height: 66rpx;
}

.cut-icon.grid-4 {
  grid-template-columns: repeat(2, 1fr);
  width: 66rpx;
  height: 66rpx;
}

.mini-cell {
  background: #cbd5e1;
  border-radius: 4rpx;
}

.cut-item.active .mini-cell {
  background: #6366f1;
}

.cut-name {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.cut-item.active .cut-name {
  color: #6366f1;
  font-weight: 600;
}

/* 底部栏 (与 longpic 统一) */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx;
  z-index: 100;
}

.btn-icon {
  width: 88rpx !important; height: 88rpx !important;
  background: #f1f5f9; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; padding: 0 !important; margin: 0 !important;
  flex-shrink: 0;
  line-height: 1 !important; 
}

.btn-primary {
  flex: 1; 
  height: 88rpx; 
  background: #6366f1; 
  color: #fff;
  border-radius: 44rpx; 
  font-size: 32rpx; 
  font-weight: 600;
  margin: 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 加载中 */
.loading-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
}
.loading-box {
  background: #ffffff; padding: 48rpx 64rpx;
  border-radius: var(--radius-lg);
  display: flex; flex-direction: column; align-items: center;
}
.loading-spinner {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid #e2e8f0; border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-text { margin-top: 24rpx; font-size: 28rpx; color: var(--text-secondary); }
@keyframes spin { to { transform: rotate(360deg); } }