<view class="container">
  <view class="page-header">
    <text class="page-title">九宫格切图</text>
    <text class="page-subtitle">形状蒙版 · 拖拽调整 · 高清无损</text>
  </view>

  <view class="card preview-card">
    <view class="upload-area" bindtap="chooseImage" wx:if="{{!imagePath}}">
      <text class="upload-icon">🍱</text>
      <text class="upload-text">点击选择图片</text>
    </view>
    
    <view class="preview-wrapper" wx:else>
      <view class="crop-container" style="width:{{cropW}}px; height:{{cropH}}px;">
        <view class="bg-layer"></view>

        <movable-area class="crop-area mask-{{maskType}}" scale-area style="width:{{cropW}}px; height:{{cropH}}px;">
          <movable-view 
            class="crop-img" 
            direction="all" 
            out-of-bounds="{{true}}"
            damping="50" friction="2" scale="{{true}}"
            scale-min="0.5" scale-max="5.0" scale-value="{{scale}}"
            x="{{x}}" y="{{y}}"
            style="width:{{imgW}}px; height:{{imgH}}px;"
          >
            <image src="{{imagePath}}" mode="scaleToFill" style="width:100%; height:100%; display:block;"></image>
          </movable-view>
        </movable-area>

        <view class="grid-lines">
            <view class="line-container-h">
                <view class="grid-line-h" wx:for="{{rows-1}}" wx:key="*this"></view>
            </view>
            <view class="line-container-v">
                <view class="grid-line-v" wx:for="{{cols-1}}" wx:key="*this"></view>
            </view>
        </view>

        <view class="reset-btn" catchtap="resetView">↺ 还原</view>
      </view>
      <view class="crop-tip">💡 {{tipText}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{imagePath}}">
    <view class="section-title">选择形状</view>
    <scroll-view class="shape-scroll" scroll-x="true">
        <view class="shape-item {{maskType==='none'?'active':''}}" bindtap="setMaskType" data-type="none">
            <view class="s-icon s-square"></view><text>原图</text>
        </view>
        <view class="shape-item {{maskType==='circle'?'active':''}}" bindtap="setMaskType" data-type="circle">
            <view class="s-icon s-circle"></view><text>圆形</text>
        </view>
        <view class="shape-item {{maskType==='heart'?'active':''}}" bindtap="setMaskType" data-type="heart">
            <view class="s-icon s-heart"></view><text>心形</text>
        </view>
        <view class="shape-item {{maskType==='star'?'active':''}}" bindtap="setMaskType" data-type="star">
            <view class="s-icon s-star"></view><text>五角星</text>
        </view>
        <view class="shape-item {{maskType==='bear'?'active':''}}" bindtap="setMaskType" data-type="bear">
            <view class="s-icon s-bear"></view><text>猫咪</text>
        </view>
        <view class="shape-item {{maskType==='flower'?'active':''}}" bindtap="setMaskType" data-type="flower">
            <view class="s-icon s-flower"></view><text>花朵</text>
        </view>
    </scroll-view>

    <view class="section-title" style="margin-top:30rpx;">选择网格</view>
    <view class="cut-options-row">
        <view class="cut-item {{gridType === 9 ? 'active' : ''}}" bindtap="setGridType" data-type="9">
            <view class="cut-icon grid-9"><view class="mini-cell" wx:for="{{9}}" wx:key="*this"></view></view>
            <text class="cut-name">九宫格</text>
        </view>
        <view class="cut-item {{gridType === 4 ? 'active' : ''}}" bindtap="setGridType" data-type="4">
            <view class="cut-icon grid-4"><view class="mini-cell" wx:for="{{4}}" wx:key="*this"></view></view>
            <text class="cut-name">四宫格</text>
        </view>
        <view class="cut-item {{gridType === 6 ? 'active' : ''}}" bindtap="setGridType" data-type="6">
            <view class="cut-icon grid-6"><view class="mini-cell" wx:for="{{6}}" wx:key="*this"></view></view>
            <text class="cut-name">六宫格</text>
        </view>
        <view class="cut-item {{gridType === 3 ? 'active' : ''}}" bindtap="setGridType" data-type="3">
            <view class="cut-icon grid-3"><view class="mini-cell" wx:for="{{3}}" wx:key="*this"></view></view>
            <text class="cut-name">竖长图</text>
        </view>
    </view>
  </view>

  <view class="ad-container" style="padding: 20rpx 30rpx;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view class="bottom-bar" wx:if="{{imagePath}}">
    <button class="btn-icon" bindtap="chooseImage">🔄</button>
    <button class="btn-icon" open-type="share">📤</button>
    <button class="btn-primary" bindtap="saveToAlbum">保存所有图片</button>
  </view>

  <view style="height: 200rpx;" wx:if="{{imagePath}}"></view>

  <view class="loading-overlay" wx:if="{{isProcessing}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
  </view>
</view>