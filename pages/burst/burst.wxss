/* pages/burst/burst.wxss */
page { 
  height: 100vh; 
  overflow: hidden; 
  background-color: #f5f5f7; 
  display: flex; 
  flex-direction: column;
}

.container { 
  flex: 1;
  width: 100%;
  display: flex; 
  flex-direction: column; 
  padding: 0 32rpx calc(140rpx + env(safe-area-inset-bottom)); 
  box-sizing: border-box;
  overflow: hidden;
}

.content-area {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start; 
  padding-top: 20rpx;
}

.card { 
  background: #fff; 
  border-radius: 32rpx; 
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05); 
  overflow: hidden; 
  margin-bottom: 24rpx; 
  width: 100%; 
}

.editor-card { 
  padding: 0; 
  display: flex; 
  flex-direction: column;
  justify-content: flex-start;
}

.feature-tip {
  text-align: center;
  padding: 16rpx 0;
  background-color: #fefce8;
  color: #854d0e;
  font-size: 24rpx;
  border-bottom: 1rpx solid #fef08a;
  width: 100%;
}

.upload-container {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.editor-card .upload-area {
  background: #fafafa; 
  padding: 140rpx 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 4rpx dashed #e2e8f0; 
  border-radius: 24rpx;
}

.upload-icon { font-size: 100rpx; margin-bottom: 30rpx; line-height: 1; }
.upload-text { font-size: 32rpx; color: #666; font-weight: 600; margin-bottom: 16rpx; }
.upload-hint { font-size: 26rpx; color: #94a3b8; }

.edit-card { 
  padding: 20rpx 0; 
  background: transparent; 
  box-shadow: none; 
  overflow: visible; 
  align-items: center;
}

.editor-frame { position: relative; background: transparent; flex-shrink: 0; }

/* 🔥 固定提示条 */
.fixed-hint {
  position: absolute;
  top: -60rpx; left: 0; right: 0;
  text-align: center;
  color: #64748b;
  font-size: 24rpx;
  background: rgba(255,255,255,0.8);
  padding: 8rpx 0;
  border-radius: 30rpx;
  margin: 0 40rpx;
  pointer-events: none;
  z-index: 50;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.bg-container {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background: #2c2c2c;
  border-radius: 12rpx;
  overflow: hidden; 
  box-shadow: 0 12rpx 30rpx rgba(0,0,0,0.2);
  z-index: 1;
}

.bg-layer { width: 100%; height: 100%; display: block; }

.grid-cells-layer {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  z-index: 5;
  display: flex;
  flex-wrap: wrap;
}
.grid-cell {
  width: 33.33%;
  height: 33.33%;
  box-sizing: border-box;
  position: relative;
  transition: opacity 0.2s;
}
.grid-cell:active { opacity: 0.8; background: rgba(255,255,255,0.1); }
.cell-image { width: 100%; height: 100%; display: block; }

.grid-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; }
.h-line { position: absolute; left: 0; width: 100%; background: #ffffff; opacity: 1; }
.v-line { position: absolute; top: 0; height: 100%; background: #ffffff; opacity: 1; }

.fg-area { 
  position: absolute; 
  width: 500%; height: 500%; 
  left: -200%; top: -200%; 
  z-index: 20; 
  pointer-events: none; 
}
.fg-view { width: 10%; height: auto; display: flex; align-items: center; justify-content: center; pointer-events: auto; }
.fg-image { width: 100%; display: block; }

.add-fg-placeholder { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; z-index: 30; pointer-events: none; }
.dashed-box { pointer-events: auto; width: 240rpx; height: 240rpx; border: 4rpx dashed rgba(255,255,255,0.6); border-radius: 24rpx; background: rgba(0,0,0,0.3); backdrop-filter: blur(4px); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.plus-icon { font-size: 60rpx; color: #fff; font-weight: 300; margin-bottom: 10rpx; }
.plus-text { font-size: 26rpx; color: #fff; font-weight: 600; }

.tool-header { 
  width: 100%; 
  display: flex; align-items: center; 
  margin-top: 40rpx; 
  padding: 20rpx 30rpx; box-sizing: border-box; 
  background: #fff; border-radius: 24rpx;
  position: relative; z-index: 100; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  flex-shrink: 0;
}
.tool-label { font-size: 28rpx; color: #475569; font-weight: 600; margin-right: 20rpx; white-space: nowrap; }
.tool-slider { flex: 1; margin: 0 20rpx; }

.reset-btn {
  font-size: 26rpx; color: #6366f1; background: #eff6ff;
  padding: 12rpx 30rpx; border-radius: 30rpx;
  font-weight: 600;
}
.reset-btn:active { opacity: 0.7; }

.ad-container { width: 100%; flex-shrink: 0; }

.bottom-bar { 
  position: fixed; bottom: 0; left: 0; right: 0; 
  background: #fff; padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom)); 
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); 
  z-index: 200; 
}
.action-row { display: flex; align-items: center; justify-content: space-between; gap: 30rpx; }
.circle-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; }
.circle-btn text:first-child { font-size: 44rpx; background: #f1f5f9; width: 88rpx; height: 88rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.btn-label { font-size: 22rpx; color: #64748b; font-weight: 500; }
.save-btn { flex: 1; height: 88rpx; background: #6366f1; color: #fff; border-radius: 44rpx; font-size: 32rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.3); margin: 0; }
.save-btn[disabled] { background: #e2e8f0; color: #94a3b8; box-shadow: none; }

.loading-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.loading-box { background: #fff; padding: 40rpx 60rpx; border-radius: 24rpx; display: flex; flex-direction: column; align-items: center; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 5rpx solid #e2e8f0; border-top-color: #6366f1; border-radius: 50%; animation: spin 0.8s linear infinite; }
.loading-text { margin-top: 20rpx; font-size: 26rpx; color: #64748b; }
@keyframes spin { to { transform: rotate(360deg); } }