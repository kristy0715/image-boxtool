<view class="container">
  <view class="page-header">
    <text class="page-title">3D冲出特效</text>
    <text class="page-subtitle">九宫格切分 · 前景自由悬浮</text>
  </view>

  <view class="content-area">
    <view class="card editor-card" wx:if="{{!bgPath}}">
      <view class="feature-tip">
        <text>🚀 选择背景图，自动生成3D九宫格</text>
      </view>
      <view class="upload-container">
        <view class="upload-area" bindtap="chooseBgImage">
          <text class="upload-icon">🏞️</text>
          <text class="upload-text">点击选择背景图</text>
          <text class="upload-hint">自动分割九宫格 · 支持拖拽人物和底图</text>
        </view>
      </view>
    </view>

    <view class="card edit-card" wx:else>
      
      <view class="fixed-hint" style="position: relative; text-align: center; color: #64748b; font-size: 26rpx; margin-bottom: 20rpx; z-index: 1;">👆 点击九宫格可单独替换底图</view>

      <view class="editor-frame" style="width:{{editorSize}}px; height:{{editorSize}}px; margin: 0 auto;">

        <view class="bg-container" bindtap="onEditorTap">
          
          <movable-area class="bg-layer">
            <movable-view 
              class="bg-img-view"
              direction="all" out-of-bounds="{{true}}" scale="{{true}}" scale-min="1" scale-max="5.0" scale-value="{{bgScale}}"
              x="{{bgX}}" y="{{bgY}}" style="width:{{bgImgW}}px; height:{{bgImgH}}px;"
              bindchange="onBgChange" bindscale="onBgScale"
              damping="100" friction="10"
            >
              <image src="{{bgPath}}" style="width:100%; height:100%; display:block;"></image>
            </movable-view>
          </movable-area>
          
          <view class="grid-cells-layer" style="pointer-events: none;">
            <view class="grid-cell" wx:for="{{gridIndices}}" wx:key="*this" data-index="{{item}}">
              <image wx:if="{{gridOverrides[item]}}" src="{{gridOverrides[item]}}" class="cell-image" mode="aspectFill"></image>
            </view>
          </view>

          <view class="grid-overlay" style="pointer-events: none;">
            <view class="h-line" style="top: 33.33%; height: {{gapSize}}px; margin-top: -{{gapSize/2}}px;"></view>
            <view class="h-line" style="top: 66.66%; height: {{gapSize}}px; margin-top: -{{gapSize/2}}px;"></view>
            <view class="v-line" style="left: 33.33%; width: {{gapSize}}px; margin-left: -{{gapSize/2}}px;"></view>
            <view class="v-line" style="left: 66.66%; width: {{gapSize}}px; margin-left: -{{gapSize/2}}px;"></view>
          </view>
        </view>

        <movable-area class="fg-area" style="z-index: 100;">
          <movable-view 
            wx:if="{{mattePath}}"
            class="fg-view"
            direction="all"
            scale="{{true}}"
            scale-min="0.5"
            scale-max="4.0"
            out-of-bounds="{{true}}"
            x="{{fgX}}"
            y="{{fgY}}"
            bindchange="onFgChange"
            bindscale="onFgScale" 
            style="pointer-events: auto;"
            damping="100" friction="10"
          >
            <image src="{{mattePath}}" class="fg-image" mode="widthFix"></image>
          </movable-view>
        </movable-area>

        <view class="add-fg-placeholder" wx:if="{{!mattePath}}" bindtap="chooseFgImage" style="z-index: 100;">
          <view class="dashed-box">
            <text class="plus-icon">＋</text>
            <text class="plus-text">添加冲出人物</text>
          </view>
        </view>
      </view>

      <view class="tool-header" style="position: relative; z-index: 1;">
        <view class="tool-label">间距</view>
        <slider class="tool-slider" min="0" max="30" value="{{gapSize}}" block-size="18" bindchanging="onGapChange" activeColor="#6366f1" backgroundColor="#e2e8f0"/>
        <view class="reset-btn" bindtap="resetEditor">还原</view>
      </view>

      <view class="tune-row" style="position: relative; z-index: 1;" wx:if="{{mattePath}}">
        <view class="tool-label">前景微调</view>
        <view class="tune-btns">
          <view class="tune-btn" bindtap="tuneFgMove" data-dir="up">▲</view>
          <view class="tune-btn" bindtap="tuneFgMove" data-dir="down">▼</view>
          <view class="tune-btn" bindtap="tuneFgMove" data-dir="left">◀</view>
          <view class="tune-btn" bindtap="tuneFgMove" data-dir="right">▶</view>
        </view>
      </view>

    </view>
  </view>

  <view class="ad-container" style="padding: 10rpx 0;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view class="bottom-bar" wx:if="{{bgPath}}">
    <view class="action-row">
      <view class="circle-btn" bindtap="chooseBgImage">
        <text>🖼️</text>
        <text class="btn-label">换底图</text>
      </view>
      <view class="circle-btn" bindtap="chooseFgImage">
        <text>👤</text>
        <text class="btn-label">{{mattePath?'换人物':'加人物'}}</text>
      </view>
      <button class="save-btn" bindtap="saveToAlbum" disabled="{{!mattePath}}">
        生成高清大图
      </button>
    </view>
  </view>

  <view class="loading-overlay" wx:if="{{isProcessing}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
  </view>
</view>