<view class="container">
  <view class="page-header">
    <text class="page-title">3D冲出特效</text>
    <text class="page-subtitle">九宫格切分 · 前景自由悬浮</text>
  </view>

  <view class="content-area">
    <view class="card editor-card" wx:if="{{!bgPath}}">
      <view class="feature-tip">
        <text>🚀 选择背景图，自动生成3D九宫格</text>
      </view>
      <view class="upload-container">
        <view class="upload-area" bindtap="chooseBgImage">
          <text class="upload-icon">🏞️</text>
          <text class="upload-text">点击选择背景图</text>
          <text class="upload-hint">自动分割九宫格 · 支持拖拽人物</text>
        </view>
      </view>
    </view>

    <view class="card edit-card" wx:else>
      <view class="editor-frame" style="width:{{editorSize}}px; height:{{editorSize}}px;">
        
        <view class="fixed-hint">👆 点击九宫格可单独替换底图</view>

        <view class="bg-container">
          <image src="{{bgPath}}" class="bg-layer" mode="aspectFill"></image>
          
          <view class="grid-cells-layer">
            <view class="grid-cell" wx:for="{{gridIndices}}" wx:key="*this" bindtap="chooseCellImage" data-index="{{item}}">
              <image wx:if="{{gridOverrides[item]}}" src="{{gridOverrides[item]}}" class="cell-image" mode="aspectFill"></image>
            </view>
          </view>

          <view class="grid-overlay">
            <view class="h-line" style="top: 33.33%; height: {{gapSize}}px; margin-top: -{{gapSize/2}}px;"></view>
            <view class="h-line" style="top: 66.66%; height: {{gapSize}}px; margin-top: -{{gapSize/2}}px;"></view>
            <view class="v-line" style="left: 33.33%; width: {{gapSize}}px; margin-left: -{{gapSize/2}}px;"></view>
            <view class="v-line" style="left: 66.66%; width: {{gapSize}}px; margin-left: -{{gapSize/2}}px;"></view>
          </view>
        </view>

        <movable-area class="fg-area">
          <movable-view 
            wx:if="{{mattePath}}"
            class="fg-view"
            direction="all"
            scale="{{true}}"
            scale-min="0.5"
            scale-max="4.0"
            out-of-bounds="{{true}}"
            x="{{fgX}}"
            y="{{fgY}}"
            bindchange="onFgChange"
            bindscale="onFgScale" 
          >
            <image src="{{mattePath}}" class="fg-image" mode="widthFix"></image>
          </movable-view>
        </movable-area>

        <view class="add-fg-placeholder" wx:if="{{!mattePath}}" bindtap="chooseFgImage">
          <view class="dashed-box">
            <text class="plus-icon">＋</text>
            <text class="plus-text">添加冲出人物</text>
          </view>
        </view>
      </view>

      <view class="tool-header">
        <view class="tool-label">间距</view>
        <slider class="tool-slider" min="0" max="30" value="{{gapSize}}" block-size="18" bindchanging="onGapChange" activeColor="#6366f1" backgroundColor="#e2e8f0"/>
        <view class="reset-btn" bindtap="resetEditor">还原</view>
      </view>

    </view>
  </view>

  <view class="ad-container" style="padding: 10rpx 0;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view class="bottom-bar" wx:if="{{bgPath}}">
    <view class="action-row">
      <view class="circle-btn" bindtap="chooseBgImage">
        <text>🖼️</text>
        <text class="btn-label">换底图</text>
      </view>
      <view class="circle-btn" bindtap="chooseFgImage">
        <text>👤</text>
        <text class="btn-label">{{mattePath?'换人物':'加人物'}}</text>
      </view>
      <button class="save-btn" bindtap="saveToAlbum" disabled="{{!mattePath}}">
        生成高清大图
      </button>
    </view>
  </view>

  <view class="loading-overlay" wx:if="{{isProcessing}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
  </view>
</view>