<view class="container">
  <view class="page-header">
    <text class="page-title">图片裁剪</text>
    <text class="page-subtitle">选择比例 · 拖动缩放 · 完美构图</text>
  </view>

  <view class="card preview-card">
    <view class="upload-area" bindtap="chooseImage" wx:if="{{!imagePath}}">
      <text class="upload-icon">✂️</text>
      <text class="upload-text">点击选择图片</text>
    </view>
    
    <view class="crop-container" wx:else>
      <view class="crop-mask"></view>

      <movable-area 
        class="crop-area" 
        style="width:{{cropWidth}}px; height:{{cropHeight}}px;"
      >
        <movable-view 
          class="crop-view" 
          direction="all" 
          scale="{{true}}" 
          scale-min="0.5" 
          scale-max="3" 
          out-of-bounds="{{true}}"
          x="{{imgX}}"
          y="{{imgY}}"
          scale-value="{{imgScale}}"
          bindchange="onInteractionChange"
          style="width:{{imgDisplayW}}px; height:{{imgDisplayH}}px;"
        >
          <image class="target-image" src="{{imagePath}}" mode="scaleToFill"></image>
        </movable-view>
      </movable-area>

      <view class="crop-border" style="width:{{cropWidth}}px; height:{{cropHeight}}px;"></view>

      <view class="loading-mask" wx:if="{{isCropping}}">
        <view class="spinner"></view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{imagePath}}">
    <view class="section-title">选择裁剪比例</view>
    <view class="ratio-grid">
      <view 
        class="ratio-item {{selectedRatio === item.id ? 'active' : ''}}"
        wx:for="{{ratioList}}"
        wx:key="id"
        bindtap="selectRatio"
        data-id="{{item.id}}"
      >
        <view class="ratio-icon" style="aspect-ratio: {{item.ratio || 1}};">
          <text wx:if="{{item.id === 'free'}}" style="font-size: 32rpx;">🖐️</text>
          <text wx:else class="ratio-text">{{item.label}}</text>
        </view>
        <text class="ratio-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="ad-container" style="padding: 20rpx 30rpx;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view class="bottom-bar" wx:if="{{imagePath}}">
    <view class="btn-group">
      <button class="btn-icon" bindtap="chooseImage">🔄</button>
      <button class="btn-icon" bindtap="resetPosition">↺</button>
    </view>

    <button class="btn-primary" wx:if="{{selectedRatio === 'free'}}" bindtap="startFreeCrop">进入自由裁剪</button>
    <button class="btn-primary" wx:else bindtap="saveImage">确认裁剪并保存</button>
  </view>

  <view style="height: 220rpx;" wx:if="{{imagePath}}"></view>
</view>