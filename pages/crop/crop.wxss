/* pages/crop/crop.wxss */

.preview-card {
  padding: 0;
  overflow: hidden;
}

.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.upload-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 30rpx; color: #64748b; }

/* === 核心：裁剪交互区 === */
.crop-container {
  width: 100%;
  height: 600rpx; 
  background: #1a1a1a; 
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

/* 蒙版层 */
.crop-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6); 
  pointer-events: none;
  z-index: 1;
}

/* 裁剪框 */
.crop-area {
  background: transparent;
  z-index: 10;
  overflow: hidden;
  /* 超大阴影作为遮罩 */
  box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.2); 
}

/* 图片容器 */
.crop-view {
  display: flex;
  justify-content: center;
  align-items: center;
}

.target-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 裁剪框边框 (无十字线) */
.crop-border {
  position: absolute;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 30rpx rgba(0, 0, 0, 0.3);
  pointer-events: none;
  z-index: 20;
}

/* Loading */
.loading-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 50;
}
.spinner {
  width: 50rpx; height: 50rpx; border: 6rpx solid #fff; border-top-color: #6366f1; border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* === 底部样式 (美化版) === */
.section-title { font-size: 26rpx; font-weight: 600; color: #1e293b; margin-bottom: 16rpx; }

/* 紧凑网格布局 (4列) */
.ratio-grid { 
  display: grid; 
  grid-template-columns: repeat(4, 1fr); 
  gap: 12rpx;
}

.ratio-item { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 10rpx; 
  border-radius: 12rpx;
  border: 2rpx solid transparent; 
  background: #f8fafc; 
  transition: all 0.2s;
}

.ratio-item.active { 
  background: #eff6ff; 
  border-color: #6366f1;
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.15);
}

.ratio-icon { 
  width: 50rpx; 
  max-height: 50rpx; 
  background: #cbd5e1;
  border-radius: 8rpx; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  margin-bottom: 6rpx; 
  overflow: hidden; 
}

.ratio-item.active .ratio-icon { background: #6366f1; }
.ratio-text { font-size: 16rpx; color: #fff; font-weight: bold; }
.ratio-name { font-size: 20rpx; color: #64748b; } 
.ratio-item.active .ratio-name { color: #6366f1; font-weight: 600; }

.bottom-bar { 
  display: flex !important; 
  align-items: center; 
  justify-content: space-between; 
  gap: 24rpx; /* 增加间距 */
  position: fixed; 
  bottom: 0;
  left: 0; 
  right: 0; 
  background: rgba(255, 255, 255, 0.95); /* 毛玻璃背景 */
  backdrop-filter: blur(20rpx);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom)); /* 增加上下内边距 */
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

/* 🌟 放大后的重新选择按钮 */
.btn-icon { 
  width: 96rpx !important; 
  height: 96rpx !important; 
  padding: 0;
  margin: 0; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  background: #f1f5f9; 
  border-radius: 50%; 
  font-size: 40rpx; /* 图标放大 */
  color: #475569; 
  flex-shrink: 0; /* 防止被挤压 */
}

/* 🌟 放大后的主按钮 */
.btn-primary { 
  flex: 1;
  height: 96rpx; /* 按钮增高 */
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); /* 渐变色 */
  color: #fff; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  border-radius: 48rpx; /* 药丸形状更圆润 */
  font-size: 32rpx; /* 字号变大 */
  font-weight: 600; 
  margin: 0;
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.25); /* 增加按钮阴影 */
}