/* pages/success/success.wxss */
page {
  background-color: #f5f5f7;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 状态提示区 */
.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.icon-wrapper {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 50%;
  padding: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.15);
  display: flex;
  justify-content: center;
  align-items: center;
}

.status-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 28rpx;
  color: #64748b;
}

/* 照片展示区 */
.preview-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  width: 100%;
}

.photo-frame {
  background: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.08);
  /* 稍微旋转一点点，增加设计感 */
  transform: rotate(-2deg);
  transition: transform 0.3s ease;
}

.photo-frame:active {
  transform: scale(0.98) rotate(-2deg);
}

.result-img {
  height: 500rpx;
  min-width: 300rpx;
  border-radius: 4rpx;
  display: block;
}

.preview-tip {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

/* 按钮区 */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 主分享按钮 - 微信绿渐变 */
.btn-share {
  width: 100% !important;
  background: linear-gradient(135deg, #07c160 0%, #05a350 100%);
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 12rpx 30rpx rgba(7, 193, 96, 0.25);
  transition: all 0.2s;
  border: none;
}

.btn-share::after { border: none; }

.btn-share:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.2);
}

.btn-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.btn-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
  line-height: 1;
}

.btn-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.btn-icon {
  font-size: 56rpx;
}

/* 次要按钮组 */
.secondary-actions {
  display: flex;
  gap: 24rpx;
}

.btn-secondary, .btn-primary-outline {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 24rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-secondary {
  background: #ffffff !important;
  color: #64748b;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.btn-primary-outline {
  background: #ffffff !important;
  color: #6366f1;
  border: 2rpx solid #e0e7ff;
}

.btn-secondary:active, .btn-primary-outline:active {
  background: #f8fafc !important;
  transform: scale(0.98);
}

/* 动画效果 */
.fade-in {
  animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
}
.fade-in-delay {
  animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  opacity: 0;
}
.fade-in-delay-2 {
  animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.img-wrapper {
  border-radius: 4rpx;
  overflow: hidden;
}