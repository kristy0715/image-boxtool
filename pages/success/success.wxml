<view class="container">
  <view class="status-area fade-in">
    <view class="icon-wrapper">
      <icon type="success" size="50" color="#07c160"></icon>
    </view>
    <text class="status-title">保存成功</text>
    <text class="status-desc">
      {{type === 'video' ? '视频已保存到系统相册' : '图片已保存到系统相册'}}
    </text>
  </view>

  <view class="preview-area fade-in-delay">
    <view class="photo-frame">
      <view class="img-wrapper">
        <image
          src="{{imagePath}}"
          mode="heightFix"
          class="result-img"
          bindtap="previewImage"
          show-menu-by-longpress
        ></image>
      </view>
    </view>
    <text class="preview-tip">{{type === 'video' ? '视频封面预览' : '点击图片预览'}}</text>
  </view>

  <view class="action-area fade-in-delay-2">
    <button class="btn-share" open-type="share">
      <view class="btn-content">
        <text class="btn-title">分享给朋友</text>
        <text class="btn-subtitle">推荐好用的工具给他们</text>
      </view>
      <text class="btn-icon">🎁</text>
    </button>

    <view class="secondary-actions">
      <button class="btn-secondary" bindtap="goHome">返回首页</button>
      <button class="btn-primary-outline" bindtap="makeAnother">
        {{type === 'video' ? '继续提取' : '再做一张'}}
      </button>
    </view>
  </view>

  <view class="ad-container fade-in-delay-2" style="width: 100%; margin-top: 40rpx;">
    <ad unit-id="adunit-ecfcec4c6a0c871b"></ad>
  </view>
</view>
