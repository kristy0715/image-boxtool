/* pages/idphoto/idphoto.wxss */
page { background-color: #f7f8fa; padding-bottom: 40rpx; }
.container { padding: 20rpx 30rpx; }

/* 标题水平排列 */
.page-header { padding: 10rpx 0 30rpx; display: flex; align-items: baseline; gap: 16rpx; }
.page-title { font-size: 40rpx; font-weight: bold; color: #1e293b; }
.page-subtitle { font-size: 26rpx; color: #64748b; }

/* === 顶部卡片 === */
.preview-card { background: #fff; border-radius: 32rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); margin-bottom: 30rpx; }
.upload-area { padding: 120rpx 40rpx; display: flex; flex-direction: column; align-items: center; background: #f8fafc; border: 4rpx dashed #cbd5e1; margin: 30rpx; border-radius: 24rpx; transition: all 0.2s; }
.upload-area:active { background: #f1f5f9; border-color: #94a3b8; }
.upload-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 32rpx; font-weight: bold; color: #334155; margin-bottom: 12rpx; }
.upload-hint { font-size: 24rpx; color: #94a3b8; }

.image-show-area { width: 100%; height: 600rpx; display: flex; align-items: center; justify-content: center; background: #f1f5f9; position: relative; }
.result-image { width: 100%; height: 100%; }

/* === 控制面板 === */
.control-panel { background: #fff; border-radius: 32rpx; padding: 30rpx 0 40rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); }

/* 🌟 美颜开关高亮面板 (微调了渐变和阴影，极其显眼) */
.highlight-panel {
  background: linear-gradient(135deg, #f0fdf4 0%, #e0e7ff 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.08);
  border: 2rpx solid #ffffff;
}
.settings-text-group { display: flex; flex-direction: column; }
.settings-title { font-size: 30rpx; font-weight: 800; color: #3730a3; margin-bottom: 6rpx; }
.settings-desc { font-size: 22rpx; color: #4f46e5; opacity: 0.85; }

.section-title { font-size: 30rpx; font-weight: bold; color: #1e293b; padding: 0 30rpx; margin-bottom: 20rpx; display: flex; align-items: center; }
.scroll-hint { font-size: 22rpx; color: #94a3b8; font-weight: normal; margin-left: 12rpx; }

.scroll-row { width: 100%; white-space: nowrap; height: 130rpx; }
.size-list { display: inline-flex; padding: 0 30rpx 0 30rpx; gap: 20rpx; padding-right: 60rpx; }
.size-item { display: inline-flex; flex-direction: column; justify-content: center; background: #f8fafc; border: 2rpx solid transparent; padding: 20rpx 30rpx; border-radius: 16rpx; min-width: 140rpx; text-align: center; transition: all 0.2s; }
.size-item.active { background: #eef2ff; border-color: #6366f1; }
.size-name { font-size: 28rpx; font-weight: bold; color: #334155; margin-bottom: 4rpx; }
.size-item.active .size-name { color: #4f46e5; }
.size-dimension { font-size: 20rpx; color: #94a3b8; }
.size-item.active .size-dimension { color: #818cf8; }

.color-list { display: inline-flex; padding: 0 30rpx 0 30rpx; gap: 24rpx; padding-right: 60rpx; }
.color-item { display: inline-flex; flex-direction: column; align-items: center; gap: 12rpx; }
.color-circle { width: 80rpx; height: 80rpx; border-radius: 50%; box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.1); position: relative; transition: transform 0.2s; }
.color-circle:active { transform: scale(0.9); }
.color-circle.border-gray { border: 2rpx solid #e2e8f0; }
.color-check { position: absolute; color: white; font-size: 36rpx; font-weight: bold; top: 50%; left: 50%; transform: translate(-50%, -50%); }
.color-check.dark { color: #1e293b; }
.color-name { font-size: 22rpx; color: #64748b; }
.color-name.active-text { color: #1e293b; font-weight: bold; }

.ad-container { border-radius: 24rpx; overflow: hidden; margin-bottom: 30rpx; }

/* 底部栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); z-index: 100; display: flex; gap: 20rpx; }
.btn-icon { width: 96rpx !important; height: 96rpx !important; padding: 0; margin: 0; display: flex; align-items: center; justify-content: center; background: #f1f5f9; border-radius: 50%; font-size: 40rpx; color: #475569; flex-shrink: 0; }
.btn-secondary { flex: 1; height: 96rpx; background: #f1f5f9; color: #475569; display: flex; align-items: center; justify-content: center; border-radius: 48rpx; font-size: 30rpx; font-weight: 600; margin: 0; }
.btn-primary { flex: 1.2; height: 96rpx; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #fff; display: flex; align-items: center; justify-content: center; border-radius: 48rpx; font-size: 30rpx; font-weight: 600; margin: 0; box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.25); }
.btn-primary.full-width { flex: 1; }

/* === 弹窗样式 === */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.modal-content { width: 600rpx; background: #fff; border-radius: 32rpx; padding: 40rpx; box-sizing: border-box; }
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; color: #1e293b; }
.input-row { display: flex; align-items: center; margin-bottom: 24rpx; }
.input-row text { font-size: 30rpx; color: #334155; width: 140rpx; }
.input-row input { flex: 1; border: 2rpx solid #cbd5e1; border-radius: 16rpx; padding: 16rpx 24rpx; font-size: 30rpx; color: #1e293b; background: #f8fafc; }
.color-preview { width: 100%; height: 120rpx; border-radius: 20rpx; margin-bottom: 30rpx; border: 2rpx solid #e2e8f0; box-shadow: inset 0 2rpx 10rpx rgba(0,0,0,0.05); }
.color-hint { font-size: 22rpx; color: #94a3b8; text-align: center; display: block; margin-top: -10rpx; margin-bottom: 20rpx; }
.modal-actions { display: flex; gap: 24rpx; margin-top: 40rpx; }
.btn-cancel { flex: 1; background: #f1f5f9; color: #475569; font-size: 30rpx; font-weight: bold; border-radius: 100rpx; height: 88rpx; display: flex; align-items: center; justify-content: center; margin: 0;}
.btn-confirm { flex: 1; background: #6366f1; color: #fff; font-size: 30rpx; font-weight: bold; border-radius: 100rpx; height: 88rpx; display: flex; align-items: center; justify-content: center; margin: 0;}
.btn-cancel::after, .btn-confirm::after { display: none; }