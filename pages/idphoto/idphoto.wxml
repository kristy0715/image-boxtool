<view class="container">
  <view class="page-header">
    <text class="page-title">AI 智能证件照</text>
    <text class="page-subtitle">自动裁剪 · 发丝级换底</text>
  </view>

  <view class="preview-card">
    <view class="upload-area" bindtap="chooseImage" wx:if="{{!rawImagePath}}">
      <text class="upload-icon">📸</text>
      <text class="upload-text">点击拍摄/上传正面照</text>
      <text class="upload-hint">无需绿幕，纯净背景效果更佳</text>
    </view>
    
    <view class="image-show-area" wx:else>
      <image class="result-image" src="{{processedImage || rawImagePath}}" mode="aspectFit"></image>
    </view>
  </view>

  <view class="control-panel" wx:if="{{rawImagePath}}">
    
    <view class="highlight-panel">
      <view class="settings-text-group">
        <text class="settings-title">✨ AI 智能美颜精修</text>
        <text class="settings-desc">一键磨皮亮肤，提升五官立体感</text>
      </view>
      <switch checked="{{useBeauty}}" bindchange="toggleBeauty" color="#4f46e5"/>
    </view>

    <view class="section-title">📐 选择尺寸 <text class="scroll-hint">(左右滑动查看更多)</text></view>
    <scroll-view scroll-x class="scroll-row" enable-flex>
      <view class="size-list">
        <view class="size-item {{selectedSize === item.id ? 'active' : ''}}" 
          wx:for="{{sizeList}}" wx:key="id" 
          bindtap="selectSize" data-id="{{item.id}}">
          <text class="size-name">{{item.name}}</text>
          <text class="size-dimension">{{item.dimension}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="section-title" style="margin-top: 40rpx;">🎨 选择背景色 <text class="scroll-hint">(左右滑动查看更多)</text></view>
    <scroll-view scroll-x class="scroll-row" enable-flex>
      <view class="color-list">
        <view class="color-item" wx:for="{{colorList}}" wx:key="value" bindtap="selectColor" data-value="{{item.value}}">
          <view class="color-circle {{item.value === '#ffffff' ? 'border-gray' : ''}}" 
            style="background: {{item.value === 'custom' ? '#f8fafc' : item.value}}; display: flex; align-items: center; justify-content: center;">
            <text wx:if="{{item.value === 'custom'}}">🎨</text>
            <view class="color-check" wx:elif="{{selectedColor === item.value && item.value !== '#ffffff'}}">✓</view>
            <view class="color-check dark" wx:elif="{{selectedColor === item.value && item.value === '#ffffff'}}">✓</view>
          </view>
          <text class="color-name {{selectedColor === item.value ? 'active-text' : ''}}">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

  </view>

  <view class="ad-container" wx:if="{{bannerUnitId}}">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view style="height: 240rpx;"></view>

  <view class="bottom-bar" wx:if="{{rawImagePath}}">
    <button class="btn-icon" bindtap="chooseImage">🔄</button>
    
    <button class="btn-secondary" bindtap="goToLayout">🖨️ 去排版</button>

    <block wx:if="{{!processedImage}}">
      <button class="btn-primary" bindtap="generateIdPhoto">开始制作</button>
    </block>
    <block wx:else>
      <button class="btn-primary" bindtap="saveImage">保存相册</button>
    </block>
  </view>

  <view class="modal-mask" wx:if="{{showCustomSizeModal}}">
    <view class="modal-content">
      <view class="modal-title">自定义尺寸 (像素)</view>
      <view class="input-row">
        <text>宽度：</text>
        <input type="number" value="{{customW}}" bindinput="onCustomWInput" placeholder="例如: 300" />
      </view>
      <view class="input-row">
        <text>高度：</text>
        <input type="number" value="{{customH}}" bindinput="onCustomHInput" placeholder="例如: 400" />
      </view>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="closeCustomSize">取消</button>
        <button class="btn-confirm" bindtap="confirmCustomSize">确定</button>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showCustomColorModal}}">
    <view class="modal-content">
      <view class="modal-title">自定义调色板</view>
      <view class="color-preview" style="background-color: {{customColorHex}}"></view>
      <view class="input-row">
        <text>HEX值：</text>
        <input type="text" value="{{customColorHex}}" bindinput="onCustomColorInput" placeholder="例如: #ff0000" maxlength="7"/>
      </view>
      <text class="color-hint">填入包含 # 的6位十六进制颜色值</text>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="closeCustomColor">取消</button>
        <button class="btn-confirm" bindtap="confirmCustomColor">确定</button>
      </view>
    </view>
  </view>

</view>