/* pages/meme/meme.wxss */
page {
  background-color: #f7f8fa;
}

.container {
  padding: 30rpx;
  padding-bottom: 160rpx;
}

.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #64748b;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.preview-card {
  padding: 0;
  overflow: hidden;
  background: #eee;
  position: relative;
  display: flex;
  justify-content: center;
}

.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

.upload-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666;
  font-weight: normal;
}

.canvas-box {
  position: relative;
  margin: 0 auto;
}

.main-canvas {
  display: block;
}

.touch-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 5;
}

.text-item {
  position: absolute;
  white-space: nowrap;
  padding: 10rpx;
  border: 2rpx dashed transparent;
  user-select: none;
}

.text-item.active {
  border-color: #6366f1;
  background: rgba(99, 102, 241, 0.1);
}

.action-row {
  display: flex;
  margin-bottom: 30rpx;
}

.text-editor {
  border-top: 2rpx solid #f1f5f9;
  padding-top: 20rpx;
}

.input-row, .slider-row, .color-row, .switch-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.text-input {
  flex: 1;
  background: #f8fafc;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.label {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
}

.val {
  width: 60rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.slider {
  flex: 1;
  margin: 0 20rpx;
}

.color-picker {
  flex: 1;
  display: flex;
  gap: 16rpx;
  margin-left: 20rpx;
  flex-wrap: wrap;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #e2e8f0;
}

.color-item.active {
  transform: scale(1.1);
  border-color: #6366f1;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.no-text-tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.btn-secondary {
  background: #f1f5f9;
  color: #333;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.btn-danger {
  background: #fef2f2;
  color: #ef4444;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.btn-primary {
  background: #6366f1;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}