/* pages/meme/meme.wxss */

/* 1. 预览卡片容器：无内边距，为了让画布撑满 */
.preview-card {
  padding: 0;
  overflow: hidden;
  min-height: auto;
  display: flex;
  flex-direction: column;
}

/* 2. 上传区域样式 */
.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

.upload-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666;
  font-weight: normal;
}

/* 3. 画布容器 */
.canvas-box {
  position: relative;
  overflow: hidden;
  margin: 0 auto;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  background: #eee;
}

.main-canvas {
  display: block;
  position: absolute;
  top: 0; left: 0;
  z-index: 1;
}

/* 4. 触摸交互层 */
.touch-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 10;
}

/* 5. 可操作的文字控件 */
.text-item {
  position: absolute;
  white-space: nowrap;
  font-weight: bold;
  padding: 10rpx 20rpx;
  border: 2px solid transparent;
  user-select: none;
  transform-origin: center center;
}

.text-item.active {
  border: 2px dashed #6366f1;
  background: rgba(99, 102, 241, 0.15);
}

/* 旋转手柄 */
.rotate-handle {
  position: absolute;
  bottom: -36rpx; right: -36rpx;
  width: 48rpx; height: 48rpx;
  background: #6366f1;
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  z-index: 30;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 删除手柄 */
.delete-handle {
  position: absolute;
  top: -26rpx; left: -26rpx;
  width: 44rpx; height: 44rpx;
  background: #ef4444;
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  z-index: 30;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 6. 工具栏 */
.tool-bar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tool-btn {
  background: #f1f5f9;
  color: #333;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  display: flex; align-items: center;
  border: none; margin: 0;
}
.tool-btn.add-btn {
  background: #6366f1;
  color: #fff;
}
.tool-btn .icon {
  margin-right: 8rpx; font-size: 32rpx;
}

/* 7. 属性面板 */
.attr-panel {
  border-top: 2rpx solid #f1f5f9;
  padding-top: 24rpx;
}
.panel-title {
  font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx;
}
.input-row, .slider-row, .color-row, .switch-row {
  display: flex; align-items: center; margin-bottom: 24rpx;
}
.text-input {
  flex: 1; background: #f8fafc;
  padding: 16rpx; border-radius: 12rpx;
  font-size: 28rpx; margin-left: 20rpx;
}

.label { width: 80rpx; font-size: 26rpx; color: #666; }
.val { width: 60rpx; font-size: 24rpx; color: #999; text-align: right; }
.slider { flex: 1; margin: 0 20rpx; }

/* 颜色选择器 */
.color-picker {
  flex: 1;
  display: flex; gap: 16rpx; margin-left: 20rpx; flex-wrap: wrap;
}
.color-item {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  border: 2rpx solid #e2e8f0;
}
.color-item.active {
  transform: scale(1.1); border-color: #6366f1; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.no-text-tip {
  text-align: center; color: #999; font-size: 26rpx; padding: 40rpx 0;
}

/* 8. 底部栏 - 标准化 */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx; z-index: 100;
}

.btn-icon {
  width: 88rpx !important; height: 88rpx;
  background: #f1f5f9; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; padding: 0; margin: 0;
}

.btn-primary {
  flex: 2; background: #6366f1; color: #fff;
  font-size: 32rpx; font-weight: 600; border-radius: 44rpx;
  margin: 0; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}