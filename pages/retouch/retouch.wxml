<view class="container">
  <view class="page-header">
    <text class="page-title">一键精修</text>
    <text class="page-subtitle">智能美颜 · 色彩焕新</text>
  </view>

  <view class="card preview-card">
    <view class="upload-area" bindtap="chooseImage" wx:if="{{!imagePath}}">
      <text class="upload-icon">✨</text>
      <text class="upload-text">点击选择照片</text>
    </view>
    
    <view class="preview-wrapper" wx:else>
      <view class="compare-container" bindtouchstart="onPreviewTouchStart" bindtouchend="onPreviewTouchEnd">
        <canvas type="2d" id="retouchCanvas" class="preview-canvas" style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"></canvas>
        
        <view class="compare-tag {{showingOriginal ? 'show' : ''}}">原图</view>
        <view class="compare-hint" wx:if="{{isProcessed}}">长按对比</view>
        
        <view class="change-btn" catchtap="chooseImage">更换</view>
      </view>
    </view>
  </view>

  <view class="card action-card" wx:if="{{imagePath && !isProcessed && !isProcessing}}">
    <button class="magic-btn" bindtap="autoRetouch">
      <text class="magic-icon">🪄</text>
      <text>一键智能美颜</text>
    </button>
  </view>

  <view class="card edit-card" wx:if="{{isProcessed}}">
    <view class="panel-title">色彩微调</view>
    <view class="slider-group">
      <view class="slider-row">
        <text class="label">亮度</text>
        <slider class="slider" min="-50" max="50" value="{{brightness}}" bindchange="onParamChange" data-param="brightness" activeColor="#6366f1" block-size="18"/>
      </view>
      <view class="slider-row">
        <text class="label">对比度</text>
        <slider class="slider" min="-50" max="50" value="{{contrast}}" bindchange="onParamChange" data-param="contrast" activeColor="#6366f1" block-size="18"/>
      </view>
      <view class="slider-row">
        <text class="label">饱和度</text>
        <slider class="slider" min="-50" max="50" value="{{saturation}}" bindchange="onParamChange" data-param="saturation" activeColor="#6366f1" block-size="18"/>
      </view>
      <view class="slider-row">
        <text class="label">色温</text>
        <slider class="slider" min="-50" max="50" value="{{temperature}}" bindchange="onParamChange" data-param="temperature" activeColor="#6366f1" block-size="18"/>
      </view>
    </view>
  </view>

  <view class="ad-container" style="padding: 20rpx 0;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>
  <view style="height: 220rpx;"></view>
  <view class="bottom-bar" wx:if="{{imagePath}}">
    <button class="btn-icon" open-type="share">📤</button>
    <button class="btn-secondary" bindtap="resetAll" wx:if="{{isProcessed}}">重置</button>
    <button class="btn-primary full-width" bindtap="saveImage">保存到相册</button>
  </view>

  <view class="loading-mask" wx:if="{{isProcessing}}">
    <view class="loading-content">
      <view class="spinner"></view>
      <text>{{processingText}}</text>
      <view class="progress-bar" wx:if="{{progress > 0}}">
        <view class="progress-inner" style="width: {{progress + '%'}};"></view>
      </view>
    </view>
  </view>
</view>