/* pages/retouch/retouch.wxss */
page {
  background-color: #f7f8fa;
}

.container {
  padding: 30rpx;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

/* 预览区 - 无内边距 */
.preview-card {
  padding: 0;
  overflow: hidden;
  min-height: auto;
}

/* 上传区域样式 */
.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

.upload-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666;
  font-weight: normal;
}

.preview-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 30rpx;
  box-sizing: border-box;
  background: #fcfcfc;
  min-height: 400rpx;
}

.compare-container {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

/* 悬浮更换按钮 */
.change-btn {
  position: absolute;
  top: 20rpx; right: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  z-index: 10;
}

.compare-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
}
.compare-tag.show { opacity: 1; }

.compare-hint {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
  pointer-events: none;
}

/* 一键美化按钮 */
.magic-btn {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.3);
  padding: 24rpx 0;
}
.magic-icon { margin-right: 12rpx; }

/* 工具卡片 */
.tabs {
  display: flex;
  border-bottom: 2rpx solid #f0f2f5;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  padding-bottom: 10rpx;
}

.tab-item.active {
  color: #6366f1;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -22rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #6366f1;
  border-radius: 6rpx;
}

/* 参数调节 */
.slider-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.slider-row .label { width: 80rpx; font-size: 26rpx; color: #666; }
.slider-row .val { width: 60rpx; font-size: 24rpx; color: #999; text-align: right; }
.slider { flex: 1; margin: 0 20rpx; }

/* 滤镜列表 */
.filter-scroll { white-space: nowrap; }
.filter-list { display: flex; gap: 20rpx; padding-right: 20rpx;}
.filter-item {
  display: flex;
  flex-direction: column; align-items: center;
  padding: 10rpx; border-radius: 12rpx; transition: all 0.2s;
}
.filter-item.active { background: #f0f2ff; }
.filter-preview {
  width: 80rpx;
  height: 80rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; margin-bottom: 10rpx;
  border: 2rpx solid #eee;
}
.filter-item.active .filter-preview { border-color: #6366f1; }
.filter-name { font-size: 22rpx; color: #666; }

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0;
  left: 0; right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx;
  z-index: 100;
}

.btn-icon {
  width: 88rpx !important; height: 88rpx;
  background: #f1f5f9; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; padding: 0; margin: 0;
}

.btn-secondary {
  flex: 1; background: #f1f5f9;
  color: #333;
  font-size: 30rpx; border-radius: 44rpx;
  margin: 0; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}

.btn-primary {
  flex: 2; background: #6366f1; color: #fff;
  font-size: 32rpx; font-weight: 600; border-radius: 44rpx;
  margin: 0; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}
.btn-primary.full-width { flex: 1; }

.loading-mask {
  position: absolute; top: 0; left: 0;
  right: 0; bottom: 0;
  background: rgba(255,255,255,0.85);
  display: flex; align-items: center;
  justify-content: center;
  z-index: 50; backdrop-filter: blur(4px);
}
.loading-content {
  display: flex; flex-direction: column; align-items: center;
  font-size: 28rpx; color: #6366f1;
  font-weight: 500;
  width: 80%;
}
.spinner {
  width: 50rpx;
  height: 50rpx;
  border: 5rpx solid #e0e7ff; border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite; margin-bottom: 20rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }

.progress-box {
  width: 100%;
  display: flex; flex-direction: column; align-items: center;
  margin-top: 16rpx;
}
.progress-text {
  font-size: 24rpx; color: #999; margin-top: 10rpx;
}
progress { width: 100%; }