page { background-color: #f7f8fa; padding-bottom: 40rpx; }
.container { padding: 20rpx 30rpx; }

/* 顶部引导条 */
.guide-banner {
  background: #eff6ff; border-radius: 16rpx; padding: 20rpx 24rpx;
  margin-bottom: 24rpx; border: 1rpx solid #dbeafe;
}
.guide-content { display: flex; align-items: center; }
.guide-icon { margin-right: 12rpx; font-size: 32rpx; }
.guide-text { color: #1e40af; font-size: 26rpx; font-weight: 500; }

/* 主卡片 */
.card {
  background: #fff; border-radius: 24rpx; padding: 0; min-height: 500rpx;
  display: flex; flex-direction: column; justify-content: flex-start;
  margin-bottom: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); overflow: hidden;
}

/* 上传区 */
.upload-area {
  padding: 120rpx 40rpx; display: flex; flex-direction: column; align-items: center;
  background: #f8fafc; border: 4rpx dashed #cbd5e1; margin: 30rpx; border-radius: 24rpx; transition: all 0.2s;
}
.upload-area:active { background: #f1f5f9; border-color: #94a3b8; }
.upload-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 32rpx; color: #334155; font-weight: bold; margin-bottom: 12rpx; }
.upload-hint { font-size: 24rpx; color: #94a3b8; }

/* 预览区 */
.preview-container {
  position: relative; width: 100%; font-size: 0;
}

/* 结果区 */
.section-title { display: flex; justify-content: space-between; align-items: center; font-size: 30rpx; font-weight: bold; color: #1e293b; }
.compare-btn { background: #f1f5f9; color: #475569; font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 30rpx; font-weight: normal; }
.compare-btn:active { background: #e2e8f0; }
.compare-tag { position: absolute; top: 20rpx; left: 20rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 12rpx; pointer-events: none; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.95); backdrop-filter: blur(20rpx);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); z-index: 100;
}
.action-row { display: flex; gap: 16rpx; }
.btn-secondary, .btn-primary, .btn-warn {
  margin: 0; border: none; font-size: 28rpx; font-weight: 600;
  height: 96rpx; line-height: 96rpx; border-radius: 100rpx;
  display: flex; align-items: center; justify-content: center;
}
.btn-secondary::after, .btn-primary::after, .btn-warn::after { display: none; }
.btn-secondary { flex: 1; background: #f1f5f9; color: #475569; }
.btn-warn { flex: 1; background: #fff7ed; color: #ea580c; }
.btn-primary { flex: 2; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #ffffff; box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.25); }

/* 加载遮罩 */
.loading-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.85); backdrop-filter: blur(8px); z-index: 999; display: flex; align-items: center; justify-content: center; }
.loading-box { background: rgba(0,0,0,0.82); padding: 50rpx 70rpx; border-radius: 32rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.15); }
.loading-spinner { width: 80rpx; height: 80rpx; border: 6rpx solid rgba(255,255,255,0.2); border-top-color: #fff; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 30rpx; }
.loading-text { color: #fff; font-size: 30rpx; font-weight: 600; letter-spacing: 2rpx; margin-bottom: 12rpx; }
.loading-sub { color: rgba(255,255,255,0.6); font-size: 24rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
