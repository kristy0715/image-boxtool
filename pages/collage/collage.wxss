/* pages/collage/collage.wxss */

/* 1. 预览区域 */
.preview-area {
  background: #eef2f6;
  /* 移除 border-radius 和 overflow:hidden，让其铺满宽度 */
  /* border-radius: 24rpx; */
  /* overflow: hidden; */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* 移除左右 padding，防止挤压内容 */
  padding: 40rpx 0; 
  margin-bottom: 24rpx;
  min-height: 600rpx;
  /* 增加最小高度 */
}

/* 初始上传区域 */
.preview-card {
  padding: 0;
  overflow: hidden;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin: 30rpx; /* 只有初始状态需要 margin */
}

.upload-area {
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  line-height: 1 !important; 
}

.upload-text {
  font-size: 30rpx;
  color: #64748b;
}

/* 滚动预览容器 */
.preview-scroll {
  width: 100%;
  /* 移除高度限制，让内容自然撑开 */
  /* min-height: 500rpx; */
  display: flex;
  /* ❌ 修复Bug：移除强制水平居中，防止横向长图左侧被截断无法滚动 */
  /* justify-content: center; */
  align-items: flex-start; 
}

.collage-board {
  position: relative;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
  /* 加深阴影，更有立体感 */
  transition: all 0.2s ease;
  /* 关键：自动居中 */
  margin: 0 auto; 
  flex-shrink: 0;
}

.collage-item {
  position: absolute;
  transition: all 0.2s ease;
}

.item-number {
  position: absolute;
  background: rgba(0,0,0,0.6);
  color: #fff;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: bold;
  z-index: 10;
}

.preview-tip {
  font-size: 24rpx; color: #94a3b8; margin-top: 30rpx;
}

/* 2. 管理栏 */
.manage-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 24rpx 24rpx; /* 左右留边 */
}
.section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx;
}

.manage-scroll { white-space: nowrap; height: 120rpx; }
.manage-list { display: flex; gap: 20rpx; }

.manage-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.manage-item image { width: 100%; height: 100%; }

.delete-btn {
  position: absolute;
  top: 0; right: 0;
  background: rgba(0,0,0,0.5); color: #fff;
  width: 40rpx; height: 40rpx;
  border-bottom-left-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; line-height: 1;
}

.add-btn {
  border: 2rpx dashed #cbd5e1;
  position: relative; 
}
.add-btn::before {
  content: ''; position: absolute;
  top: 50%; left: 50%;
  width: 30%; height: 4rpx;
  background-color: #cbd5e1;
  transform: translate(-50%, -50%); border-radius: 4rpx;
}
.add-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%; height: 30%; width: 4rpx;
  background-color: #cbd5e1;
  transform: translate(-50%, -50%); border-radius: 4rpx;
}

/* 3. 设置区域 */
.setting-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 30rpx;
  /* 左右留边 */
}

.setting-group { margin-bottom: 40rpx; }
.group-header { display: flex; justify-content: space-between; margin-bottom: 10rpx; }
.group-title { font-size: 28rpx; font-weight: 600;
  color: #333; }
.group-val { font-size: 26rpx; color: #6366f1; }

.layout-tabs {
  display: flex; background: #f1f5f9;
  border-radius: 16rpx; padding: 6rpx;
  margin-top: 20rpx;
}
.layout-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0; font-size: 28rpx; color: #64748b;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.layout-tab.active {
  background: #fff;
  color: #6366f1; font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.color-list { display: flex; gap: 24rpx; padding: 10rpx 0; }
.color-item {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  border: 2rpx solid #e2e8f0;
  flex-shrink: 0;
  display: flex; align-items: center;
  justify-content: center;
}
.color-item.active { border-color: #6366f1; transform: scale(1.1);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1); }
.check { color: #999; font-size: 24rpx; font-weight: bold; }
.color-item[style*="#ffffff"] .check { color: #333;
}
.color-item[style*="#000000"] .check { color: #fff; }

.setting-row-between { display: flex; justify-content: space-between; align-items: center;
}

/* 4. 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx;
  z-index: 100;
}

.btn-icon {
  width: 88rpx !important; height: 88rpx !important;
  background: #f1f5f9; border-radius: 44rpx;
  display: flex; align-items: center;
  justify-content: center;
  font-size: 40rpx; padding: 0 !important; margin: 0 !important;
  flex-shrink: 0;
  line-height: 1 !important; 
}

.btn-primary {
  flex: 1;
  height: 88rpx; 
  background: #6366f1; color: #fff;
  border-radius: 44rpx; 
  font-size: 32rpx; font-weight: 600;
  margin: 0;
  display: flex !important; align-items: center;
  justify-content: center;
  padding: 0;
}
.btn-primary[disabled] { background: #e2e8f0; color: #94a3b8; }

/* Loading */
.loading-overlay {
  position: fixed; top: 0;
  left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex; align-items: center; justify-content: center; z-index: 1000;
}
.loading-box {
  background: #ffffff; padding: 48rpx 64rpx; border-radius: 24rpx;
  display: flex; flex-direction: column; align-items: center;
}
.loading-spinner {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid #e2e8f0; border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.loading-text { margin-top: 24rpx; font-size: 28rpx; color: #64748b; }
@keyframes spin { to { transform: rotate(360deg); } }