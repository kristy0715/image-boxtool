/* pages/longpic/longpic.wxss */

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.text-btn {
  font-size: 26rpx;
  color: #6366f1;
  padding: 10rpx;
}

.text-btn.warning {
  color: #ef4444;
}

.add-btn-small {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #f0f1f5;
  border-radius: 30rpx;
  color: #333;
  font-size: 24rpx;
}
.add-btn-small .add-icon { margin-right: 4rpx; font-size: 30rpx; line-height: 1; }

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: calc(25% - 12rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8f8f8;
}

/* === 核心修复：使用 CSS 绘制绝对居中的加号 === */
.add-item {
  border: 2rpx dashed #cbd5e1;
  position: relative; /* 为伪元素定位 */
  /* 不需要 Flex 居中文字了，直接用定位画图 */
}

/* 横线 */
.add-item::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 30%; /* 宽度占容器的30% */
  height: 4rpx; /* 线条粗细 */
  background-color: #cbd5e1;
  transform: translate(-50%, -50%);
  border-radius: 4rpx;
}

/* 竖线 */
.add-item::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  height: 30%; /* 高度占容器的30% */
  width: 4rpx;
  background-color: #cbd5e1;
  transform: translate(-50%, -50%);
  border-radius: 4rpx;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-index {
  position: absolute;
  top: 0;
  left: 0;
  padding: 4rpx 10rpx;
  background: rgba(0, 0, 0, 0.5);
  border-bottom-right-radius: 12rpx;
  color: #fff;
  font-size: 20rpx;
}

.item-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 12rpx;
  z-index: 2;
  line-height: 1; 
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  /* 修复：确保 emoji 图标本身也是 Flex 居中显示 */
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1; 
  height: 80rpx; /* 显式高度 */
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 设置项 */
.setting-row {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.setting-row:last-child {
  margin-bottom: 0;
}

.setting-label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.slider-box {
  flex: 1;
  margin: 0 10rpx;
}

.setting-slider {
  margin: 0;
}

.setting-val-box {
    display: flex;
    align-items: center;
    gap: 10rpx;
}

.setting-value {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--text-light);
}

.auto-btn {
    font-size: 22rpx;
    background: #eff6ff;
    color: #3b82f6;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
    border: 1rpx solid #dbeafe;
}

.color-list {
  display: flex;
  gap: 16rpx;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.color-item.active {
  border-color: #6366f1;
  transform: scale(1.1);
  box-shadow: 0 4rpx 10rpx rgba(99, 102, 241, 0.2);
}
.color-check { color: #fff; font-size: 24rpx; }

/* 结果预览 */
.result-scroll {
  max-height: 600rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.result-image {
  width: 100%;
  display: block;
}

.result-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 16rpx;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 100;
}

.btn-icon {
  width: 88rpx !important;
  height: 88rpx !important;
  background: #f1f5f9;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  padding: 0 !important;
  margin: 0 !important;
  flex-shrink: 0;
  /* 确保图标绝对居中 */
  line-height: 1 !important; 
}

.btn-secondary {
  flex: 1;
  background: #f1f5f9;
  color: #333;
  font-size: 30rpx;
  border-radius: 44rpx;
  margin: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  flex: 2;
  background: #6366f1;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary.full-width {
  flex: 1;
}

/* 加载中 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-box {
  background: #ffffff;
  padding: 48rpx 64rpx;
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}