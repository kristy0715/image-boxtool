<view class="container">
  <view class="page-header">
    <text class="page-title">长图拼接</text>
    <text class="page-subtitle">聊天截图、多图无缝拼接</text>
  </view>

  <view class="card">
    <view class="section-header">
      <text class="section-title">已选图片 ({{imageList.length}})</text>
      <view class="header-actions">
        <view class="text-btn warning" bindtap="clearImages" wx:if="{{imageList.length > 0}}">清空</view>
        <view class="add-btn-small" bindtap="addImages">
          <text class="add-icon">+</text>
          <text>添加</text>
        </view>
      </view>
    </view>
    
    <view class="image-list" wx:if="{{imageList.length > 0}}">
      <view class="image-item" wx:for="{{imageList}}" wx:key="index">
        <image class="item-image" src="{{item}}" mode="aspectFill"></image>
        <view class="item-index">{{index + 1}}</view>
        <view class="item-delete" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="image-item add-item" bindtap="addImages" wx:if="{{imageList.length < 50}}"></view>
    </view>

    <view class="empty-tip" wx:else bindtap="addImages">
      <text class="empty-icon">📜</text>
      <text class="empty-text">点击添加图片</text>
      <text class="empty-hint">支持聊天记录、截图自动拼接</text>
    </view>
  </view>

  <view class="card" wx:if="{{imageList.length > 0}}">
    <view class="section-title">拼接设置</view>
    
    <view class="setting-row">
      <text class="setting-label">重叠 / 间距</text>
      <view class="slider-box">
        <slider class="setting-slider" min="-300" max="50" value="{{gap}}" bindchange="onGapChange" activeColor="#6366f1"/>
      </view>
      <view class="setting-val-box">
        <text class="setting-value">{{gap}}px</text>
        <view class="auto-btn" bindtap="autoDetectOverlap">🪄 智能</view>
      </view>
    </view>

    <view class="setting-row">
      <text class="setting-label">背景颜色</text>
      <view class="color-list">
        <view 
          class="color-item {{bgColor === item ? 'active' : ''}}"
          wx:for="{{colorList}}"
          wx:key="*this"
          style="background: {{item}};"
          bindtap="selectBgColor"
          data-color="{{item}}"
        >
          <view class="color-check" wx:if="{{bgColor === item && (item === '#ffffff' || item === '#f5f5f5' ? false : true)}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{resultImage}}">
    <view class="section-header">
      <text class="section-title">生成预览</text>
      <text class="text-btn" bindtap="previewResult">全屏查看 ›</text>
    </view>
    <scroll-view scroll-y class="result-scroll" bindtap="previewResult">
      <image class="result-image" src="{{resultImage}}" mode="widthFix"></image>
    </scroll-view>
    <view class="result-hint">点击图片可查看大图</view>
  </view>

  <view class="ad-container" style="padding: 20rpx 30rpx;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view class="bottom-bar" wx:if="{{imageList.length > 0}}">
    <block wx:if="{{resultImage}}">
      <button class="btn-icon" open-type="share">📤</button>
      <button class="btn-secondary" bindtap="generateLongPic">重生成</button>
      <button class="btn-primary" bindtap="saveImage">保存相册</button>
    </block>
    <block wx:else>
      <button class="btn-primary full-width" bindtap="generateLongPic">生成长图</button>
    </block>
  </view>

  <view style="height: 220rpx;" wx:if="{{imageList.length > 0}}"></view>

  <view class="loading-overlay" wx:if="{{isProcessing}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
  </view>
</view>