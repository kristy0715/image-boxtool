/* pages/index/index.wxss */
.container { padding: 0; background: #f5f5f7; min-height: 100vh; }

/* Hero 区域 */
.hero-section { position: relative; padding-left: 40rpx; padding-right: 40rpx; padding-bottom: 60rpx; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); overflow: hidden; border-bottom-left-radius: 48rpx; border-bottom-right-radius: 48rpx; box-shadow: 0 10rpx 30rpx rgba(118, 75, 162, 0.2); }
.hero-bg { position: absolute; top: -100rpx; right: -100rpx; width: 400rpx; height: 400rpx; background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%); border-radius: 50%; pointer-events: none; }
.hero-content { position: relative; z-index: 1; display: flex; align-items: center; }
.title-area { display: flex; align-items: center; gap: 24rpx; }
.app-logo { width: 96rpx; height: 96rpx; border-radius: 20rpx; background-color: #fff; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15); border: 2rpx solid rgba(255, 255, 255, 0.3); }
.hero-text-group { display: flex; flex-direction: column; }
.hero-title { font-size: 48rpx; font-weight: 800; color: #ffffff; letter-spacing: 2rpx; margin-bottom: 4rpx; text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1); line-height: 1.2; }
.hero-subtitle { font-size: 26rpx; color: rgba(255, 255, 255, 0.9); font-weight: 500; letter-spacing: 1rpx; }

/* 工具列表 */
.section-header { padding: 40rpx 40rpx 24rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #1e293b; position: relative; padding-left: 20rpx; }
.section-title::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 8rpx; height: 28rpx; background: #667eea; border-radius: 4rpx; }
.feature-grid { padding: 0 24rpx 10rpx; }
.feature-card { display: flex; align-items: center; background: #ffffff; border-radius: 24rpx; padding: 28rpx 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03); transition: all 0.3s ease; border: 1rpx solid rgba(0,0,0,0.02); }
.feature-card:active { transform: scale(0.98); box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05); background: #fafafa; }
.feature-icon-wrapper { width: 88rpx; height: 88rpx; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.06); }
.icon-text { font-size: 44rpx; }
.feature-info { flex: 1; margin-left: 28rpx; overflow: hidden; }
.feature-title { display: block; font-size: 32rpx; font-weight: 600; color: #1e293b; margin-bottom: 8rpx; }
.feature-desc { display: block; font-size: 24rpx; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.feature-arrow { font-size: 40rpx; color: #e2e8f0; font-weight: 300; flex-shrink: 0; margin-left: 16rpx; }
.footer { padding: 40rpx 32rpx 80rpx; text-align: center; }
.footer-text { font-size: 22rpx; color: #cbd5e1; letter-spacing: 2rpx; }

/* ================= 每日一签核心样式 (升级版：精致福袋) ================= */
.fortune-entry {
  position: fixed;
  right: 30rpx;
  bottom: 15%;
  z-index: 900;
  display: flex;
  flex-direction: column;
  align-items: center;
  /* 悬浮动画 */
  animation: floatAni 3s ease-in-out infinite;
  /* 点击时的缩放反馈 */
  transition: transform 0.1s;
}
.fortune-entry:active {
  transform: scale(0.95);
}

/* 1. 福袋主体 */
.entry-bag {
  width: 100rpx;
  height: 120rpx;
  /* 更有质感的红金渐变 */
  background: linear-gradient(180deg, #ff6b6b 0%, #ee5253 100%);
  /* 形状：下宽上窄的圆润袋子 */
  border-radius: 24rpx 24rpx 50rpx 50rpx;
  /* 增加内发光和外阴影，提升立体感 */
  box-shadow:
    inset 0 4rpx 10rpx rgba(255,255,255,0.4),  /* 顶部高光 */
    inset 0 -6rpx 10rpx rgba(0,0,0,0.1),       /* 底部暗部 */
    0 10rpx 20rpx rgba(238, 82, 83, 0.4);      /* 外部投影 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  /* 微微的描边 */
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* 2. 袋口褶皱 (使用伪元素在顶部画一个小梯形) */
.entry-bag::before {
  content: '';
  position: absolute;
  top: -12rpx;
  width: 70rpx;
  height: 20rpx;
  background: #ff6b6b;
  border-radius: 8rpx 8rpx 0 0;
  border: 2rpx solid rgba(255,255,255,0.3);
  border-bottom: none;
  z-index: 0;
}

/* 3. 金色绳结 (原来的 entry-knot) */
.entry-knot {
  position: absolute;
  top: 10rpx;
  width: 100%;
  height: 0;
  display: flex;
  justify-content: center;
  z-index: 2;
}

/* 绳子：横向金线 */
.entry-knot::before {
  content: '';
  position: absolute;
  top: 0;
  width: 84rpx;
  height: 6rpx;
  background: #feca57; /* 金色 */
  border-radius: 4rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 绳结：中间的圆扣 */
.entry-knot::after {
  content: '';
  position: absolute;
  top: -5rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ffd32a;
  border-radius: 50%;
  border: 2rpx solid #ff9f43; /* 深金描边 */
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 4. 文字样式优化 */
.entry-text {
  margin-top: 16rpx; /* 避开绳子区域 */
  font-size: 26rpx;
  color: #fff;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
  letter-spacing: 2rpx;
  /* 文字阴影，增加可读性 */
  text-shadow: 0 2rpx 2rpx rgba(162, 29, 29, 0.3);
}

/* 装饰小星星 (可选) */
.entry-text::after {
  content: '✦';
  display: block;
  font-size: 20rpx;
  color: #feca57;
  margin-top: 2rpx;
  line-height: 1;
  opacity: 0.8;
}

/* 底部悬浮阴影 */
.entry-shadow {
  width: 60rpx;
  height: 12rpx;
  background: rgba(0,0,0,0.15);
  border-radius: 50%;
  margin-top: 15rpx;
  filter: blur(4rpx);
  animation: shadowAni 3s ease-in-out infinite;
}

/* 动画定义 */
@keyframes floatAni {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
@keyframes shadowAni {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(0.85); opacity: 0.5; }
}

.fortune-modal { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1000; visibility: hidden; opacity: 0; transition: all 0.3s ease; }
.fortune-modal.show { visibility: visible; opacity: 1; }

/* 1. 还原背景渐变色（之前的蓝粉色更清新） */
.modal-bg-gradient {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  z-index: -3; 
  /* 还原为：清新的蓝粉渐变 */
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  filter: blur(25px);
  transform: scale(1.15);
}

/* 2. 精美图片背景 */
.modal-bg-image {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  z-index: -2;
  opacity: 0; 
  transition: opacity 0.5s ease-in-out; 
}
.modal-bg-image.fade-in { opacity: 1; }

/* 3. 遮罩层 - 稍微加深一点点，突出卡片 */
.modal-backdrop { position: absolute; width: 100%; height: 100%; top: 0; left: 0; background: rgba(0,0,0,0.15); z-index: -1; }

.fortune-center-container { 
  width: 100%; 
  height: 100%; 
  display: flex; 
  flex-direction: column; 
  justify-content: center; 
  align-items: center; 
  padding-bottom: 20rpx; 
  box-sizing: border-box; 
  
  /* === 关键修复 === */
  position: relative; 
  z-index: 10; /* 强制提升层级，确保在背景之上 */
}

/* 2. 还原卡片毛玻璃质感（第一版的参数） */
.ticket-card { 
  width: 600rpx; 
  
  /* 还原为：0.65 透明度，不加 saturate */
  background: rgba(255, 255, 255, 0.65); 
  
  /* 还原为：15px 模糊，这个数值最自然 */
  backdrop-filter: blur(15px); 
  -webkit-backdrop-filter: blur(15px);
  
  border-radius: 24rpx; 
  border: 1px solid rgba(255, 255, 255, 0.4);
  
  /* 还原为：柔和的阴影 */
  box-shadow: 0 40rpx 60rpx rgba(0,0,0,0.15); 
  
  padding: 40rpx; 
  box-sizing: border-box; 
  display: flex; 
  flex-direction: column; 
  margin-bottom: 50rpx; 
  position: relative; 
  
  /* 缺口保持不变 */
  -webkit-mask-image: radial-gradient(circle at left 170rpx, transparent 18rpx, black 19rpx), radial-gradient(circle at right 170rpx, transparent 18rpx, black 19rpx); 
  mask-image: radial-gradient(circle at left 170rpx, transparent 18rpx, black 19rpx), radial-gradient(circle at right 170rpx, transparent 18rpx, black 19rpx); 
  -webkit-mask-composite: source-in; 
  mask-composite: intersect; 
}

.ticket-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24rpx; height: 90rpx; }
.ticket-date { display: flex; align-items: flex-start; color: #1d1d1f; }
.ticket-date .day { font-size: 88rpx; line-height: 1; font-weight: 800; margin-right: 16rpx; font-family: 'Times New Roman', serif; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05); }
.date-right { display: flex; flex-direction: column; justify-content: flex-start; padding-top: 10rpx; }
.date-right .month { font-size: 24rpx; font-weight: 900; text-transform: uppercase; line-height: 1.2; }
.date-right .year { font-size: 20rpx; color: #555; font-weight: bold; line-height: 1.2; margin-top: 4rpx; }
.lunar-text { font-size: 28rpx; color: #333; font-weight: bold; padding-top: 8rpx; opacity: 0.8; }

.ticket-dashed-line { width: 100%; height: 0; border-bottom: 3rpx dashed rgba(0,0,0,0.1); margin-top: 10rpx; margin-bottom: 40rpx; }

.ticket-body { display: flex; flex-direction: row; }
.ticket-type-col { width: 60rpx; margin-right: 30rpx; display: flex; justify-content: center; align-items: center; background: #8B0000; border-radius: 12rpx; padding: 20rpx 0; box-sizing: border-box; height: fit-content; box-shadow: 0 4rpx 10rpx rgba(139,0,0,0.2); }
.ticket-type-text { font-size: 34rpx; font-weight: 900; writing-mode: vertical-rl; letter-spacing: 10rpx; color: #ffffff; font-family: serif; }

.ticket-content-col { flex: 1; display: flex; flex-direction: column; }
.ticket-title { font-size: 38rpx; font-weight: 900; color: #000; margin-bottom: 24rpx; letter-spacing: 2rpx; text-shadow: 0 1rpx 1rpx rgba(255,255,255,0.5); }
.ticket-desc { font-size: 28rpx; color: #333; line-height: 1.6; text-align: justify; font-weight: 500; }

.ticket-footer { border-top: 2rpx solid rgba(0,0,0,0.05); margin-top: 40rpx; padding-top: 30rpx; display: flex; flex-direction: column; align-items: center; }
.qr-img-large { width: 130rpx; height: 130rpx; margin-bottom: 16rpx; display: block; mix-blend-mode: multiply; /* 让二维码更好地融入 */ }
.qr-tip-center { font-size: 20rpx; color: #666; letter-spacing: 1rpx; }

.action-bar-fixed { width: 100%; padding: 0 40rpx; box-sizing: border-box; display: flex; justify-content: space-between; align-items: flex-end; position: relative; z-index: 100; margin-bottom: 40rpx; }
.action-side-wrapper { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; }
.action-side-wrapper.left { align-items: flex-start; }
.action-side-wrapper.right { align-items: flex-end; }
.action-center-wrapper { width: auto; display: flex; justify-content: center; align-items: flex-end; margin: 0 20rpx; }
button.reset-btn { background: transparent !important; padding: 0 !important; margin: 0 !important; line-height: 1 !important; border: none !important; width: auto !important; display: flex; flex-direction: column; align-items: flex-end; }
button.reset-btn::after { border: none; }

/* 按钮也增加一点毛玻璃感 */
.circle-btn { width: 90rpx; height: 90rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; transition: all 0.2s; background: rgba(255, 255, 255, 0.35); border: 1px solid rgba(255, 255, 255, 0.6); backdrop-filter: blur(10px); box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1); }
.circle-btn:active { transform: scale(0.9); background: rgba(255,255,255,0.5); }
.circle-btn .btn-icon { font-size: 40rpx; line-height: 1; }

.pill-btn { background: #ffffff; color: #333; height: 100rpx; padding: 0 50rpx; border-radius: 50rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.15); margin-bottom: 38rpx; border: 1px solid rgba(255,255,255,0.8); }
.pill-btn:active { transform: scale(0.95); background: #f8f8f8; }
.pill-btn .btn-icon { margin-right: 12rpx; font-size: 34rpx; }
.btn-text-nowrap { white-space: nowrap; font-size: 30rpx; font-weight: bold; letter-spacing: 1rpx; }
.btn-label { font-size: 24rpx; color: #ffffff; font-weight: bold; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5); line-height: 1.2; height: 26rpx; }
.action-side-wrapper.right .btn-label { width: 90rpx; text-align: center; }
.action-side-wrapper.left .btn-label { width: 90rpx; text-align: center; }
.close-btn-large { width: 80rpx; height: 80rpx; border-radius: 50%; background: rgba(0,0,0,0.3); border: 2rpx solid rgba(255,255,255,0.4); display: flex; align-items: center; justify-content: center; margin-top: 10rpx; }
.close-icon-large { color: #fff; font-size: 50rpx; font-weight: 300; margin-top: -6rpx; }