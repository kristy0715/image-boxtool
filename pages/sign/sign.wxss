page { background-color: #f5f6f8; font-family: -apple-system, sans-serif; }
.container { padding-bottom: calc(60rpx + env(safe-area-inset-bottom)); }

.header-bg { position: relative; width: 100%; height: 500rpx; background: linear-gradient(180deg, #ff9a3d 0%, #ff7300 100%); display: flex; flex-direction: column; align-items: center; border-radius: 0 0 10% 10% / 0 0 15% 15%; padding-top: 40rpx; box-sizing: border-box; }

.points-board { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; }
.points-label { font-size: 28rpx; color: rgba(255, 255, 255, 0.8); margin-bottom: 12rpx; }
.points-value { display: flex; justify-content: center; align-items: baseline; }
.points-value .num { font-size: 100rpx; font-weight: bold; color: #ffffff; text-shadow: 0 4rpx 12rpx rgba(204, 82, 0, 0.5); font-family: 'DIN Alternate', sans-serif; line-height: 1; }
.sign-btn-wrap { display: flex; flex-direction: column; align-items: center; }
.sign-btn { width: 320rpx; height: 96rpx; border-radius: 50rpx; display: flex; justify-content: center; align-items: center; font-size: 34rpx; font-weight: bold; transition: all 0.2s; box-shadow: 0 12rpx 24rpx rgba(204, 82, 0, 0.4); }
.sign-btn.active { background: linear-gradient(90deg, #ffffff 0%, #fff1e6 100%); color: #ff7300; }
.sign-btn.active:active { transform: scale(0.95); box-shadow: 0 4rpx 10rpx rgba(204, 82, 0, 0.4); }
.sign-btn.disabled { background: rgba(255, 255, 255, 0.3); color: #fff; box-shadow: none; border: 1px solid rgba(255,255,255,0.4); }

.sign-tips { margin-top: 24rpx; font-size: 24rpx; color: rgba(255, 255, 255, 0.9); }
.sign-tips .highlight { color: #ffe81c; font-weight: bold; font-size: 28rpx; }

.progress-card { background: #ffffff; border-radius: 24rpx; margin: -60rpx 30rpx 30rpx 30rpx; padding: 40rpx 30rpx; position: relative; z-index: 10; box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.04); }
.card-title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50rpx; }
.title-text { font-size: 32rpx; font-weight: bold; color: #333; }
.highlight-days { color: #ff7300; font-size: 40rpx; margin: 0 8rpx; }
.sub-title { font-size: 24rpx; color: #999; }

.timeline { display: flex; justify-content: space-between; position: relative; padding-top: 20rpx; }
.progress-bar-bg { position: absolute; top: 62rpx; left: 4%; width: 92%; height: 8rpx; background: #f1f5f9; border-radius: 4rpx; z-index: 1; }
.progress-bar-active { height: 100%; background: linear-gradient(90deg, #ffc085 0%, #ff7300 100%); border-radius: 4rpx; transition: width 0.5s ease-in-out; }

.day-item { display: flex; flex-direction: column; align-items: center; position: relative; z-index: 2; width: 14%; }
.reward-bubble { height: 44rpx; min-width: 44rpx; border-radius: 22rpx; display: flex; justify-content: center; align-items: center; font-size: 22rpx; font-weight: bold; margin-bottom: 12rpx; padding: 0 8rpx; box-sizing: border-box; }
.node-dot { width: 16rpx; height: 16rpx; border-radius: 50%; border: 6rpx solid #fff; background: #e2e8f0; margin-bottom: 12rpx; box-shadow: 0 0 0 2rpx #f1f5f9; }
.day-text { font-size: 22rpx; color: #94a3b8; }

.day-item.past .reward-bubble { background: #f1f5f9; color: #94a3b8; }
.day-item.past .node-dot { background: #ff7300; border-color: #fff; box-shadow: 0 0 0 2rpx #ffc085; }
.day-item.today .reward-bubble { background: #ff7300; color: #fff; position: relative; }
.day-item.today .reward-bubble::after { content: ''; position: absolute; bottom: -8rpx; left: 50%; transform: translateX(-50%); border-width: 8rpx 6rpx 0; border-style: solid; border-color: #ff7300 transparent transparent; }
.day-item.today .node-dot { background: #ff7300; border-color: #fff; box-shadow: 0 0 0 4rpx #ff7300; transform: scale(1.2); }
.day-item.today .day-text { color: #ff7300; font-weight: bold; }
.day-item.future .reward-bubble { background: #fff4ed; color: #ff9a3d; }
.day-item.future .node-dot { background: #e2e8f0; }

.history-card { background: #ffffff; border-radius: 24rpx; margin: 0 30rpx; padding: 40rpx 30rpx; box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.04); min-height: 400rpx; }
.history-card .card-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; display: block; }

/* 🌟 新增：对账单分类 Tab 样式 */
.history-tabs { display: flex; background: #F2F3F5; border-radius: 12rpx; padding: 6rpx; margin-bottom: 30rpx; }
.tab-item { flex: 1; text-align: center; font-size: 26rpx; color: #4E5969; padding: 12rpx 0; border-radius: 8rpx; transition: all 0.2s; }
.tab-item.active { background: #FFFFFF; color: #2B66FF; font-weight: bold; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05); }

.history-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1px dashed #f1f5f9; }
.history-item:last-child { border-bottom: none; }
.item-title { font-size: 28rpx; color: #333; margin-bottom: 8rpx; font-weight: 500; }
.item-time { font-size: 22rpx; color: #94a3b8; }
.item-right { font-size: 36rpx; font-weight: bold; font-family: 'DIN Alternate', sans-serif; }

/* 🌟 动态收入支出颜色 */
.item-right.plus { color: #10B981; }  /* 绿色代表收入 */
.item-right.minus { color: #1D2129; } /* 黑色代表支出 */

.empty-state { padding: 60rpx 0; text-align: center; }
.empty-text { font-size: 26rpx; color: #94a3b8; }