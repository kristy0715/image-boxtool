<view class="container">
  <view class="mode-tabs">
    <view class="tab-item {{mode === 'auto' ? 'active' : ''}}" bindtap="switchMode" data-mode="auto">
      <text>{{leftTabTitle}}</text>
    </view>
    <view class="tab-item {{mode === 'manual' ? 'active' : ''}}" bindtap="switchMode" data-mode="manual">
      <text>{{rightTabTitle}}</text>
    </view>
  </view>

  <view class="guide-banner" wx:if="{{imagePath && !resultImage}}">
    <view class="guide-content">
      <text class="guide-icon">💡</text>
      <text class="guide-text">提示：放大局部区域后再涂抹，消除效果更完美</text>
    </view>
  </view>

  <view class="card editor-card">
    <view class="feature-tip" wx:if="{{mode === 'auto'}}">
      <text>🚀 AI强力消除支持复杂背景</text>
    </view>
    <view class="feature-tip" wx:if="{{mode === 'manual'}}">
      <text>⚠️ 强力去除纯色背景前水印</text>
    </view>

    <view class="upload-area" bindtap="chooseImage" wx:if="{{!imagePath}}">
      <text class="upload-icon">✨</text>
      <text class="upload-text">点击上传图片</text>
      <text class="upload-hint">去除水印 / 字幕 / 杂物</text>
    </view>

    <view class="editor-wrapper" wx:else>
      <view class="canvas-container">
        
        <view class="zoom-badge" wx:if="{{displayScale > 1.05}}">
          <text>🔍 {{displayScale}}x 局部编辑中</text>
        </view>

        <movable-area class="move-area" style="width: {{canvasDisplayWidth}}px; height: {{canvasDisplayHeight}}px;">
          <movable-view 
            class="move-view" 
            direction="all" 
            scale="true" 
            scale-min="1" 
            scale-max="3" 
            x="{{moveX}}" 
            y="{{moveY}}" 
            scale-value="{{moveScale}}"
            disabled="{{!isMoveMode}}"
            damping="40"
            friction="2"
            bindscale="onScaleChange"
            style="width: {{canvasDisplayWidth}}px; height: {{canvasDisplayHeight}}px;"
          >
            <canvas type="2d" id="editCanvas" class="edit-canvas"
              style="width: {{canvasDisplayWidth}}px; height: {{canvasDisplayHeight}}px;"
              catchtouchstart="{{!isMoveMode ? 'onTouchStart' : ''}}"
              catchtouchmove="{{!isMoveMode ? 'onTouchMove' : ''}}"
              catchtouchend="{{!isMoveMode ? 'onTouchEnd' : ''}}"
            ></canvas>
          </movable-view>
        </movable-area>

      <view class="loading-mask" wx:if="{{isProcessing}}">
          <view class="loading-spinner"></view>
          <text>{{loadingText || (mode === 'auto' ? 'AI去水印中...' : '纯色去水印中...')}}</text>
      </view>
      </view>

      <view class="toolbar">
          <view class="tool-group">
              <view class="tool-btn" bindtap="undoAction"><text>↩️ 撤销</text></view>
              <view class="tool-btn" bindtap="clearMask"><text>🗑️ 重置</text></view>
              
              <view class="tool-btn-wrapper">
                <view class="guide-popover" wx:if="{{!isMoveMode && !hasMovedOnce}}">
                  🔍 放大局部涂抹
                </view>
                <view class="tool-btn {{isMoveMode ? 'active-tool' : ''}}" bindtap="toggleMoveMode">
                  <text>{{isMoveMode ? '👌 完成' : '✋ 移动'}}</text>
                </view>
              </view>
          </view>
          <view class="brush-indicator">
              <text wx:if="{{isMoveMode}}">双指缩放 / 单指拖动</text>
              <text wx:else>涂抹水印区域</text>
          </view>
      </view>
      
      <view class="brush-settings">
          <text class="setting-label">笔刷</text>
          <view class="brush-sizes">
            <view class="brush-size {{brushSize === 10 ? 'active' : ''}}" bindtap="setBrushSize" data-size="10">
              <view class="brush-dot" style="width: 12rpx; height: 12rpx;"></view>
            </view>
            <view class="brush-size {{brushSize === 20 ? 'active' : ''}}" bindtap="setBrushSize" data-size="20">
              <view class="brush-dot" style="width: 20rpx; height: 20rpx;"></view>
            </view>
            <view class="brush-size {{brushSize === 35 ? 'active' : ''}}" bindtap="setBrushSize" data-size="35">
              <view class="brush-dot" style="width: 32rpx; height: 32rpx;"></view>
            </view>
            <view class="brush-size {{brushSize === 50 ? 'active' : ''}}" bindtap="setBrushSize" data-size="50">
              <view class="brush-dot" style="width: 44rpx; height: 44rpx;"></view>
            </view>
          </view>
      </view>
    </view>
  </view>

  <view class="card result-card" wx:if="{{resultImage}}">
    <view class="section-title">
      <text>🎉 处理完成</text>
      <view class="compare-btn" bindtouchstart="startCompare" bindtouchend="endCompare" bindtouchcancel="endCompare">👀 长按对比原图</view>
    </view>
    <view class="result-box">
        <image class="result-image" src="{{isComparing ? imagePath : resultImage}}" mode="widthFix"></image>
        <view class="compare-tag" wx:if="{{isComparing}}">原图</view>
    </view>
  </view>

  <view class="ad-container" style="padding: 0 0 20rpx 0;">
    <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view style="height: 220rpx;"></view>

  <view class="bottom-bar">
    <view class="btn-group">
      <button class="btn-icon" bindtap="chooseImage">🔄</button>
      <button class="btn-primary" bindtap="startProcess" disabled="{{!imagePath || isProcessing}}">
        {{isProcessing ? '处理中...' : '立即消除'}}
      </button>
    </view>
    <button class="btn-save" bindtap="saveImage" disabled="{{!resultImage}}">保存到相册</button>
  </view>
</view>