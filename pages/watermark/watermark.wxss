/* pages/watermark/watermark.wxss */
page { background-color: #f7f8fa; padding-bottom: 40rpx; }
.container { padding: 20rpx 30rpx; }

/* 顶部 Tab */
.mode-tabs { display: flex; background: #fff; padding: 8rpx; border-radius: 20rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 16rpx; font-size: 28rpx; color: #666; font-weight: 500; transition: all 0.2s; }
.tab-item.active { background: #e0e7ff; color: #6366f1; font-weight: 600; }

/* 主编辑卡片 */
.editor-card { 
  background: #fff; 
  border-radius: 24rpx; 
  padding: 0; 
  min-height: 500rpx; 
  display: flex; 
  flex-direction: column; 
  justify-content: flex-start;
  margin-bottom: 30rpx; 
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  overflow: hidden; 
}

/* 提示语样式 (新增) */
.feature-tip {
  text-align: center;
  padding: 16rpx 0;
  background-color: #fefce8;
  color: #854d0e;
  font-size: 24rpx;
  border-bottom: 1rpx solid #fef08a;
  width: 100%;
}

/* 上传区域 */
.upload-area { 
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 120rpx 40rpx; width: 100%; box-sizing: border-box;
}
.upload-icon { font-size: 100rpx; margin-bottom: 20rpx; line-height: 1; }
.upload-text { font-size: 30rpx; color: #666; font-weight: normal; margin-bottom: 12rpx; }
.upload-hint { font-size: 24rpx; color: #94a3b8; }

/* 编辑区域容器 */
.editor-wrapper { padding: 24rpx; width: 100%; box-sizing: border-box; }

/* 画布容器 */
.canvas-container { 
  position: relative; 
  display: flex; justify-content: center; align-items: center; 
  background-image: linear-gradient(45deg, #eee 25%, transparent 25%, transparent 75%, #eee 75%), linear-gradient(45deg, #eee 25%, transparent 25%, transparent 75%, #eee 75%);
  background-size: 20px 20px; background-position: 0 0, 10px 10px; 
  border-radius: 12rpx; overflow: hidden; 
  box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
}

.move-area { width: 100%; height: 100%; }
.move-view { display: flex; align-items: center; justify-content: center; }

.loading-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 28rpx; color: #6366f1; z-index: 10; }
.loading-spinner {
  width: 50rpx; height: 50rpx;
  border: 5rpx solid #e0e7ff; border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite; margin-bottom: 20rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 工具栏 */
.toolbar { display: flex; justify-content: space-between; align-items: center; margin-top: 24rpx; padding: 0 10rpx; }
.tool-group { display: flex; gap: 20rpx; }
.tool-btn { background: #f1f5f9; padding: 10rpx 24rpx; border-radius: 30rpx; font-size: 24rpx; color: #475569; transition: all 0.2s; }
.tool-btn.active-tool { background: #6366f1; color: #fff; }

.brush-indicator { font-size: 24rpx; color: #94a3b8; }

.brush-settings { display: flex; align-items: center; margin-top: 24rpx; background: #f8fafc; padding: 16rpx 24rpx; border-radius: 16rpx; }
.setting-label { font-size: 26rpx; color: #64748b; margin-right: 24rpx; }
.brush-sizes { flex: 1; display: flex; align-items: center; justify-content: space-around; }
.brush-size { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; border-radius: 12rpx; }
.brush-size.active { background: #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); }
.brush-dot { background: #333; border-radius: 50%; }
.brush-size.active .brush-dot { background: #6366f1; }

/* 结果卡片 */
.result-card { background: #fff; border-radius: 24rpx; padding: 24rpx; margin-bottom: 30rpx; }
.section-title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; font-size: 30rpx; font-weight: 600; }
.compare-btn { font-size: 24rpx; color: #6366f1; background: #eff6ff; padding: 8rpx 20rpx; border-radius: 30rpx; }
.result-box { position: relative; border-radius: 12rpx; overflow: hidden; }
.result-image { width: 100%; display: block; }
.compare-tag { position: absolute; top: 20rpx; left: 20rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 24rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }

/* 广告与底部栏 */
.ad-container { width: 100%; box-sizing: border-box; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05); display: flex; align-items: center; gap: 20rpx; z-index: 100; }
.btn-group { display: flex; flex: 1; gap: 16rpx; align-items: center; }
.btn-icon { width: 88rpx !important; height: 88rpx !important; display: flex; align-items: center; justify-content: center; background: #f1f5f9; border-radius: 44rpx; font-size: 40rpx; margin: 0 !important; padding: 0 !important; }
.btn-primary { flex: 1; height: 88rpx !important; min-height: 88rpx !important; background: #6366f1; color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; margin: 0 !important; padding: 0 20rpx !important; display: flex !important; align-items: center; justify-content: center; line-height: 1 !important; }
.btn-primary[disabled] { background: #cbd5e1; color: #fff; }
.btn-save { width: 240rpx !important; height: 88rpx !important; min-height: 88rpx !important; background: #10b981; color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; margin: 0 !important; padding: 0 20rpx !important; display: flex !important; align-items: center; justify-content: center; line-height: 1 !important; }
.btn-save[disabled] { background: #e2e8f0; color: #94a3b8; }