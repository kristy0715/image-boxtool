/* pages/ocr/ocr.wxss */

/* 分步卡片 */
.step-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.step-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
  padding-bottom: 16rpx;
}

.step-badge {
  width: 44rpx;
  height: 44rpx;
  background: #e0e7ff;
  color: #6366f1;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.header-tools {
  display: flex;
  gap: 20rpx;
}

.tool-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #f1f5f9;
  color: #64748b;
  border-radius: 30rpx;
}

.tool-btn.warning {
  background: #fef2f2;
  color: #ef4444;
}

/* 步骤1：上传与预览 */
.upload-area {
  height: 200rpx;
  background: #f8fafc;
  border: 2rpx dashed #cbd5e1;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.upload-icon { font-size: 60rpx; margin-bottom: 10rpx; }
.upload-text { font-size: 28rpx; color: #94a3b8; }

.preview-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.preview-box {
  flex: 1;
  height: 220rpx;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #000;
}

.mini-img {
  width: 100%;
  height: 100%;
  opacity: 0.6;
}

.preview-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.preview-btn {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.preview-hint {
  font-size: 22rpx;
  opacity: 0.9;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.re-upload {
  width: 120rpx;
  height: 220rpx;
  background: #f1f5f9;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 16rpx;
}

/* 步骤2：粘贴区 */
.paste-zone {
  height: 240rpx;
  background: #f0fdf4; /* 淡绿色背景 */
  border: 2rpx dashed #86efac;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}
.paste-zone:active { background: #dcfce7; }

.paste-btn {
  background: #22c55e;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}
.paste-icon { margin-right: 12rpx; }
.paste-desc { font-size: 24rpx; color: #15803d; margin-top: 20rpx; }

/* 编辑区 */
.result-textarea {
  width: 100%;
  height: 360rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #334155;
}

.text-stat {
  text-align: right;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx;
  z-index: 100;
}

.btn-icon {
  width: 88rpx !important; height: 88rpx !important;
  background: #f1f5f9; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; padding: 0 !important; margin: 0 !important;
  flex-shrink: 0;
  line-height: 1 !important; 
}

.btn-primary {
  flex: 1; height: 88rpx; 
  background: #6366f1; color: #fff;
  border-radius: 44rpx; 
  font-size: 32rpx; font-weight: 600;
  margin: 0;
  display: flex !important; align-items: center; justify-content: center;
  padding: 0;
}
.btn-primary[disabled] { background: #e2e8f0; color: #94a3b8; }

/* 引导弹窗修复 */
.guide-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex; align-items: center; justify-content: center;
}

.guide-card {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.guide-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 30rpx;
  color: #1e293b;
}

.guide-steps { margin-bottom: 40rpx; }
.g-step { font-size: 28rpx; color: #475569; margin-bottom: 16rpx; }
.highlight { color: #6366f1; font-weight: bold; }

.guide-btn {
  background: #6366f1;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
}