page { background-color: #F7F8FA; font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif; }
.container { padding-bottom: env(safe-area-inset-bottom); }

/* 吸顶导航栏 */
.header-bar { 
  position: sticky; top: 0; z-index: 100; background: rgba(255, 255, 255, 0.96); backdrop-filter: blur(10px);
  height: 100rpx; border-bottom: 1rpx solid rgba(0,0,0,0.03); 
  white-space: nowrap; width: 100%; box-sizing: border-box; 
}

/* 🌟 只保留左边的 padding，右边的交给物理占位节点 */
.tabs { display: flex; height: 100%; padding-left: 32rpx; gap: 48rpx; align-items: center; }

/* 🌟 新增：占位节点的宽度，配合 gap 抵消出完美的右边距 */
.tab-placeholder {
  width: 1rpx; 
  height: 100%;
  flex-shrink: 0;
  margin-left: -16rpx; 
}

.tab-item { position: relative; display: inline-flex; align-items: center; height: 100%; transition: all 0.2s; flex-shrink: 0; }
.tab-text { font-size: 28rpx; color: #8A8F99; transition: all 0.2s; }
.tab-item.active .tab-text { font-size: 32rpx; color: #1D2129; font-weight: bold; }
.tab-line { position: absolute; bottom: 12rpx; left: 50%; transform: translateX(-50%); width: 32rpx; height: 6rpx; background: #2B66FF; border-radius: 4rpx; box-shadow: 0 2rpx 6rpx rgba(43,102,255,0.3); }

/* 内容卡片区 */
.help-content { padding: 30rpx; }
.help-card { background: #FFFFFF; border-radius: 20rpx; padding: 40rpx 30rpx; box-shadow: 0 4rpx 20rpx rgba(149, 157, 165, 0.06); }
.help-title { font-size: 32rpx; font-weight: bold; color: #1D2129; margin-bottom: 40rpx; border-left: 8rpx solid #2B66FF; padding-left: 16rpx; line-height: 1; }

/* 🌟精致化布局：步骤容器 */
.step-box { margin-bottom: 30rpx; }
.step-box:last-child { margin-bottom: 0; }

.step-item { display: flex; align-items: flex-start; margin-bottom: 15rpx; }
.step-num { flex-shrink: 0; width: 40rpx; height: 40rpx; background: #EEF2FF; color: #2B66FF; font-size: 24rpx; font-weight: bold; display: flex; justify-content: center; align-items: center; border-radius: 50%; margin-right: 20rpx; margin-top: 4rpx; }
.step-text { font-size: 28rpx; color: #4E5969; line-height: 1.6; flex: 1; word-break: break-all;}

/* 🌟 新增：示意图样式 */
.step-image { 
  width: 100%; /* 占满卡片宽度 */
  border-radius: 16rpx;              /* 圆角 */
  margin-top: 10rpx;                 /* 和文字保持距离 */
  margin-left: 60rpx; /* 对齐文字开头（num+margin） */
  width: calc(100% - 60rpx);         /* 减去左边距后的宽度 */
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03); /* 轻微阴影 */
  border: 1px solid #F1F5F9;         /* 轻微边框线 */
}

/* 🌟 新增：Banner广告样式 */
.ad-container {
  margin: 0 30rpx 30rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(149, 157, 165, 0.06);
}