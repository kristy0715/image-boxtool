/* pages/matting/matting.wxss */

/* 复用全局卡片布局 */
@import "/pages/burst/burst.wxss"; 

/* 🔥 核心修改：覆盖 burst 的固定屏样式，改为滚动布局 */
page {
  height: auto !important;
  overflow-y: auto !important;
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

.container {
  padding: 0 32rpx;
  height: auto !important;
  overflow: visible !important;
  display: block !important; /* 取消 flex column */
}

/* 页面标题微调 */
.page-header {
  padding: 40rpx 0 30rpx;
  text-align: left;
}

/* === 结果预览区美化 === */
.preview-box {
  width: 94%;
  padding: 24rpx;
  box-sizing: border-box;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.06); 
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.canvas-box {
  width: 100%; 
  height: 600rpx; 
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #f8fafc;
  display: flex; 
  align-items: center; 
  justify-content: center;
  background-color: #fff;
}

/* 棋盘格背景 */
.checkerboard {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background-image: linear-gradient(45deg, #eee 25%, transparent 25%), linear-gradient(-45deg, #eee 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #eee 75%), linear-gradient(-45deg, transparent 75%, #eee 75%);
  background-size: 20rpx 20rpx;
  background-position: 0 0, 0 10rpx, 10rpx -10rpx, -10rpx 0px;
  z-index: 0;
  opacity: 0.6;
}

.result-img {
  width: 100%; height: 100%; 
  position: relative; z-index: 10;
}

/* === 工具栏 (颜色选择) === */
.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* 增加一点底部间距，与广告拉开距离 */
  margin-bottom: 20rpx; 
}

.color-options {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end; 
  gap: 24rpx;
}

.color-circle {
  width: 52rpx; 
  height: 52rpx; 
  border-radius: 50%; 
  border: 2rpx solid rgba(0,0,0,0.1); 
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
}

/* 选中状态 */
.color-circle.active {
  transform: scale(1.2);
  border: 4rpx solid #6366f1; 
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.color-circle.checker { 
  background: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPjxyZWN0IHdpZHRoPSI4IiBoZWlnaHQ9IjgiIGZpbGw9IiNmZmYiLz48cGF0aCBkPSJNMCAwSDRWMHw0IDRIN3w4IDhIN3wwIDBINCIgZmlsbD0iI2NjYyIvPjwvc3ZnPg=='); 
}
.color-circle.white { background: #ffffff; }
.color-circle.red { background: #D9241E; }
.color-circle.blue { background: #438EDB; }
.color-circle.black { background: #000000; }

/* 底部栏样式 (确保固定) */
.bottom-bar { 
  position: fixed; bottom: 0; left: 0; right: 0; 
  background: #fff; padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom)); 
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); 
  z-index: 200; 
}