page { background-color: #F7F8FA; font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif; }
.container { padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }

/* 吸顶导航栏 */
.header-bar { position: sticky; top: 0; z-index: 100; background: rgba(255, 255, 255, 0.96); backdrop-filter: blur(10px); display: flex; justify-content: space-between; align-items: center; padding: 0 32rpx; height: 100rpx; border-bottom: 1rpx solid rgba(0,0,0,0.03); }
.tabs { display: flex; height: 100%; gap: 48rpx; }
.tab-item { position: relative; display: flex; align-items: center; height: 100%; transition: all 0.2s; }
.tab-text { font-size: 28rpx; color: #8A8F99; transition: all 0.2s; }
.tab-item.active .tab-text { font-size: 30rpx; color: #1D2129; font-weight: 600; }
.tab-line { position: absolute; bottom: 12rpx; left: 50%; transform: translateX(-50%); width: 32rpx; height: 6rpx; background: #6366f1; border-radius: 4rpx; box-shadow: 0 2rpx 6rpx rgba(99,102,241,0.4); }
.clear-btn { display: flex; align-items: center; padding: 10rpx 0; }
.clear-text { font-size: 24rpx; color: #8A8F99; font-weight: 500; }
.clear-btn:active { opacity: 0.6; }

/* 🌟 列表与卡片 (尺寸缩小，更加紧凑) */
.history-list { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.history-card { background: #FFFFFF; border-radius: 20rpx; padding: 24rpx; display: flex; gap: 20rpx; box-shadow: 0 4rpx 20rpx rgba(149, 157, 165, 0.06); transition: transform 0.15s; }
.history-card:active { transform: scale(0.98); background: #FCFCFD; }

/* 🌟 左侧头图缩小到 150rpx */
.cover-box { position: relative; width: 150rpx; height: 150rpx; flex-shrink: 0; border-radius: 12rpx; overflow: hidden; background: #F2F3F5; }
.cover-img { width: 100%; height: 100%; }
.type-badge { position: absolute; top: 8rpx; right: 8rpx; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); color: #fff; padding: 4rpx 10rpx; border-radius: 6rpx; font-size: 18rpx; font-weight: 500; }

/* 右侧内容流 */
.content-box { flex: 1; display: flex; flex-direction: column; justify-content: space-between; overflow: hidden; }

/* 🌟 顶部文案 (最多2行截断，行高减小) */
.text-area { margin-bottom: 12rpx; }
.parsed-text { font-size: 26rpx; color: #1D2129; line-height: 38rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; }

/* 🌟 底部：强行分离左右两边，绝对不会靠太近 */
.bottom-row { display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto; padding-top: 10rpx; }

.meta-left { display: flex; flex-direction: column; gap: 8rpx; flex: 1; overflow: hidden; }
.platform-tag { width: fit-content; font-size: 18rpx; color: #4F46E5; background: #EEF2FF; padding: 4rpx 10rpx; border-radius: 6rpx; font-weight: 600; }
.time-text { font-size: 20rpx; color: #86909C; font-family: 'DIN Alternate', sans-serif; white-space: nowrap; }

/* 提取按钮 (强制不压缩，留出左边距) */
.btn-extract { margin-left: 20rpx; flex-shrink: 0; font-size: 22rpx; color: #FFFFFF; background: linear-gradient(90deg, #6366f1 0%, #4f46e5 100%); padding: 12rpx 30rpx; border-radius: 32rpx; font-weight: 500; box-shadow: 0 4rpx 12rpx rgba(99,102,241,0.25); transition: opacity 0.2s; }
.btn-extract:active { opacity: 0.8; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 200rpx 0; }
.empty-icon { font-size: 40rpx; color: #C9CDD4; margin-bottom: 24rpx; font-weight: 300; }
.empty-text { font-size: 28rpx; font-weight: bold; color: #4E5969; margin-bottom: 12rpx; }
.empty-subtext { font-size: 24rpx; color: #86909C; }

/* 🌟 新增：Banner 广告容器样式 */
.ad-container {
  margin: 20rpx 24rpx 40rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(149, 157, 165, 0.06);
}