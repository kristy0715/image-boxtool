/* pages/text/text.wxss */
page { background-color: #f7f8fa; height: 100%; }
.container { padding: 30rpx; box-sizing: border-box; }

.card { background: #fff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.no-top-radius { border-top-left-radius: 0; border-top-right-radius: 0; margin-top: -24rpx; }

/* 预览区 */
.preview-card { padding: 0; overflow: hidden; min-height: auto; position: relative; display: flex; justify-content: center; align-items: center; }
.upload-area { padding: 120rpx 40rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; box-sizing: border-box; }
.upload-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 30rpx; color: #666; font-weight: normal; }

.preview-wrapper { position: relative; overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1); margin: 30rpx auto; }
.bg-image { width: 100%; height: 100%; display: block; }

/* 拖动元素通用样式 */
.drag-element { position: absolute; border: 2rpx dashed transparent; display: flex; align-items: center; justify-content: center; }
.drag-element.active { border-color: #fff; background-color: rgba(0,0,0,0.1); }
.drag-element.active::after { content: ''; position: absolute; top: -4rpx; left: -4rpx; right: -4rpx; bottom: -4rpx; border: 4rpx solid rgba(255,255,255,0.8); pointer-events: none; }

/* 🌟 防止文字被删光后变成不可点击的黑洞，并增加背景色圆角和边距 */
.text-element { 
  white-space: pre; /* 🌟 核心修复：改成 pre。强制不自动换行，只有按下回车键才换行，保持和保存结果 100% 一致！ */
  text-align: center; 
  min-width: 60rpx; 
  min-height: 50rpx;
  padding: 12rpx 24rpx; /* 新增背景内边距撑开 */
  border-radius: 16rpx; /* 新增圆角 */
  box-sizing: border-box;
}

/* 删除按钮 */
.delete-handle { position: absolute; top: -24rpx; left: -24rpx; width: 48rpx; height: 48rpx; background: #ef4444; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; line-height: 1; border: 4rpx solid #fff; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2); z-index: 200; }
/* 旋转缩放手柄 */
.transform-handle { position: absolute; bottom: -24rpx; right: -24rpx; width: 48rpx; height: 48rpx; background: #fff; color: #333; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; line-height: 1; border: 4rpx solid rgba(0,0,0,0.1); box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2); z-index: 200; }

.add-text-btn { background: #eef2ff; color: #6366f1; font-weight: 600; text-align: center; padding: 20rpx; border-radius: 16rpx; margin-bottom: 30rpx; font-size: 30rpx; }
.add-text-btn:active { background: #e0e7ff; }

.empty-tip { text-align: center; color: #94a3b8; font-size: 26rpx; padding: 20rpx 0; }

.tab-header { display: flex; background: #fff; border-radius: 24rpx 24rpx 0 0; overflow: hidden; margin-bottom: 0; border-bottom: 2rpx solid #f1f5f9; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #64748b; font-weight: 500; position: relative; }
.tab-item.active { color: #6366f1; font-weight: 600; background: #fff; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 6rpx; background: #6366f1; border-radius: 6rpx 6rpx 0 0; }

.input-row { margin-bottom: 30rpx; }
.text-input { background: #f8fafc; padding: 20rpx; border-radius: 12rpx; font-size: 30rpx; color: #333; }
.style-row { display: flex; align-items: center; margin-bottom: 30rpx; }
.style-label { width: 80rpx; font-size: 28rpx; color: #64748b; flex-shrink: 0; }
.style-slider { flex: 1; margin: 0 20rpx; }

/* 颜色滚动栏修复 */
.color-scroll { flex: 1; white-space: nowrap; width: 100%; overflow-x: auto; }
.color-list { display: flex; gap: 24rpx; padding-right: 20rpx; align-items: center; }
.color-item { width: 64rpx; height: 64rpx; border-radius: 50%; border: 2rpx solid rgba(0,0,0,0.1); flex-shrink: 0; position: relative; }
.check-mark { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 32rpx; font-weight: bold; text-shadow: 0 1px 2px rgba(0,0,0,0.3); }

/* 🌟 补充：表示“无背景”的棋盘格图案，以及在浅色块上能看清对勾的深色样式 */
.transparent-bg { background: repeating-conic-gradient(#e2e8f0 0% 25%, #ffffff 0% 50%) 50% / 20rpx 20rpx !important; }
.dark-check { color: #333 !important; text-shadow: none !important; }

.sticker-cate-tabs { display: flex; margin-bottom: 20rpx; gap: 30rpx; }
.cate-item { font-size: 26rpx; color: #94a3b8; padding: 6rpx 0; }
.cate-item.active { color: #333; font-weight: bold; border-bottom: 4rpx solid #6366f1; }

.sticker-grid-scroll { height: 320rpx; }
.sticker-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 16rpx; padding-bottom: 20rpx; }
.sticker-box { aspect-ratio: 1; background: #f8fafc; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; border: 2rpx solid transparent; overflow: hidden; }
.sticker-box:active { background: #e0e7ff; }
.sticker-emoji { font-size: 60rpx; line-height: 1; }

.control-panel { border-top: 2rpx solid #f1f5f9; padding-top: 24rpx; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05); display: flex; align-items: center; gap: 24rpx; z-index: 100; }
.btn-icon { width: 88rpx !important; height: 88rpx; background: #f1f5f9; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; padding: 0; margin: 0; }
.btn-secondary { flex: 1; height: 88rpx; background: #f1f5f9; color: #333; border-radius: 44rpx; margin: 0; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 500; }
.btn-primary { flex: 2; background: #6366f1; color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 44rpx; margin: 0; height: 88rpx; display: flex; align-items: center; justify-content: center; }