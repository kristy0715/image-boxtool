/* pages/text/text.wxss */
page {
  background-color: #f7f8fa;
  height: 100%;
}
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.no-top-radius {
  border-top-left-radius: 0; 
  border-top-right-radius: 0; 
  margin-top: -24rpx;
}

/* === 预览区 === */
.preview-card {
  padding: 0;
  overflow: hidden;
  min-height: 500rpx;
  background: #f1f5f9;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}
.upload-area {
  width: 100%; height: 100%;
  min-height: 500rpx;
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  border: 4rpx dashed #cbd5e1;
  box-sizing: border-box; 
  margin: 20rpx;
  border-radius: 24rpx;
  background-color: #f8fafc;
}
.upload-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 30rpx; color: #94a3b8; }

.preview-wrapper {
  position: relative; 
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1); 
  margin: auto;
}
.bg-image { width: 100%; height: 100%; display: block; }

/* === 拖动元素 === */
.drag-element {
  position: absolute;
  transition: all 0.1s ease-out; 
  border: 2rpx dashed transparent;
}
.drag-element.dragging { transition: none !important; opacity: 0.8; }
.drag-element.active { border-color: #fff; background-color: rgba(0,0,0,0.1); }
/* 增加选中时的边框效果 */
.drag-element.active::after {
    content: '';
    position: absolute; top: -4rpx; left: -4rpx; right: -4rpx; bottom: -4rpx;
    border: 2rpx solid #6366f1;
    pointer-events: none;
}

.text-element { white-space: pre-wrap; text-align: center; min-width: 100rpx; }
.sticker-element .ele-img { width: 100%; height: 100%; }

/* === 面板样式 === */
.tab-header {
  display: flex;
  background: #fff; border-radius: 24rpx 24rpx 0 0;
  overflow: hidden; margin-bottom: 0; border-bottom: 2rpx solid #f1f5f9;
}
.tab-item {
  flex: 1;
  text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #64748b; font-weight: 500; position: relative;
}
.tab-item.active {
  color: #6366f1; font-weight: 600;
  background: #fff;
}
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 40rpx; height: 6rpx;
  background: #6366f1; border-radius: 6rpx 6rpx 0 0;
}

.input-row { margin-bottom: 30rpx; }
.text-input { background: #f8fafc; padding: 20rpx; border-radius: 12rpx; font-size: 30rpx; color: #333; }
.style-row { display: flex; align-items: center; margin-bottom: 30rpx; }
.style-label { width: 80rpx; font-size: 28rpx; color: #64748b; }
.style-slider { flex: 1; margin: 0 20rpx; }
.style-val { width: 60rpx; text-align: right; font-size: 26rpx; color: #94a3b8; }

.color-scroll { flex: 1; white-space: nowrap; width: 0; }
.color-list { display: flex; gap: 24rpx; padding-right: 20rpx; }
.color-item {
  width: 64rpx; height: 64rpx; border-radius: 50%; border: 2rpx solid rgba(0,0,0,0.1); flex-shrink: 0; position: relative;
}
.check-mark {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 32rpx; font-weight: bold; text-shadow: 0 1px 2px rgba(0,0,0,0.3);
}

.sticker-cate-tabs { display: flex; margin-bottom: 20rpx; gap: 30rpx; }
.cate-item { font-size: 26rpx; color: #94a3b8; padding: 6rpx 0; }
.cate-item.active { color: #333; font-weight: bold; border-bottom: 4rpx solid #6366f1; }

.sticker-grid-scroll { height: 320rpx; }
.sticker-grid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 16rpx; padding-bottom: 20rpx;
}
.sticker-box {
  aspect-ratio: 1; background: #f8fafc; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center; border: 2rpx solid transparent;
  overflow: hidden; /* 防止图片溢出 */
}
.sticker-box.active { border-color: #6366f1; background: #eef2ff; }
.sticker-list-img { width: 80%; height: 80%; }

.control-panel { border-top: 2rpx solid #f1f5f9; padding-top: 24rpx; }
.delete-full-btn {
  width: 100% !important; background: #fee2e2; color: #ef4444; font-size: 28rpx; font-weight: 500; border-radius: 40rpx; padding: 18rpx 0;
}

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex; align-items: center; gap: 24rpx; z-index: 100;
}
.btn-icon {
  width: 88rpx !important; height: 88rpx; background: #f1f5f9; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center; font-size: 40rpx; padding: 0; margin: 0;
}
.btn-primary {
  flex: 2; background: #6366f1; color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 44rpx; margin: 0; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}