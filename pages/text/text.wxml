<view class="container" wx:if="{{isAllowed}}">
  <view class="page-header">
    <text class="page-title">全能创作工坊</text>
    <text class="page-subtitle">自制表情包 · 加字加图 · 贴纸水印</text>
  </view>

  <view class="card preview-card">
    <view class="upload-area" bindtap="chooseImage" wx:if="{{!imagePath}}">
      <text class="upload-icon">✏️</text>
      <text class="upload-text">点击选择照片</text>
    </view>

    <view class="preview-wrapper" wx:else style="width:{{viewWidth}}px; height:{{viewHeight}}px;" bindtap="onCanvasTap">
      <image class="bg-image" src="{{imagePath}}" mode="scaleToFill"></image>

      <block wx:for="{{elements}}" wx:key="id">
        <view wx:if="{{item.type === 'sticker'}}"
          class="drag-element sticker-element {{activeId === item.id ? 'active' : ''}}"
          style="left:{{item.x}}px; top:{{item.y}}px; width:{{item.size}}px; height:{{item.size}}px; transform: translate(-50%, -50%) rotate({{item.angle || 0}}deg); z-index: {{activeId === item.id ? 100 : 50}};"
          catchtouchstart="onTouchStart" 
          catchtouchmove="onTouchMove" 
          catchtouchend="onTouchEnd"
          data-id="{{item.id}}"
        >
          <text style="font-size: {{item.size}}px; line-height: 1;">{{item.content}}</text>
          
          <view class="delete-handle" catchtouchstart="deleteElement" data-id="{{item.id}}" wx:if="{{activeId === item.id}}">×</view>
          <view class="transform-handle" catchtouchstart="onTransformStart" catchtouchmove="onTransformMove" catchtouchend="onTransformEnd" data-id="{{item.id}}" wx:if="{{activeId === item.id}}">⤡</view>
        </view>

        <view wx:if="{{item.type === 'text'}}"
          class="drag-element text-element {{activeId === item.id ? 'active' : ''}}"
          style="left:{{item.x}}px; top:{{item.y}}px; transform: translate(-50%, -50%) rotate({{item.angle || 0}}deg); z-index: {{activeId === item.id ? 100 : 60}}; background-color: {{item.bgColor || 'transparent'}};"
          catchtouchstart="onTouchStart" 
          catchtouchmove="onTouchMove" 
          catchtouchend="onTouchEnd"
          data-id="{{item.id}}"
        >
          <text style="font-size:{{item.fontSize}}px; color:{{item.color}}; {{item.hasStroke ? 'text-shadow: 1px 1px 0 #000, -1px -1px 0 #000;' : ''}}">{{item.content || ' '}}</text>
          
          <view class="delete-handle" catchtouchstart="deleteElement" data-id="{{item.id}}" wx:if="{{activeId === item.id}}">×</view>
          <view class="transform-handle" catchtouchstart="onTransformStart" catchtouchmove="onTransformMove" catchtouchend="onTransformEnd" data-id="{{item.id}}" wx:if="{{activeId === item.id}}">⤡</view>
        </view>

        <view wx:if="{{item.type === 'image'}}"
          class="drag-element image-element {{activeId === item.id ? 'active' : ''}}"
          style="left:{{item.x}}px; top:{{item.y}}px; width:{{item.width}}px; height:{{item.height}}px; transform: translate(-50%, -50%) rotate({{item.angle || 0}}deg); z-index: {{activeId === item.id ? 100 : 40}};"
          catchtouchstart="onTouchStart" 
          catchtouchmove="onTouchMove" 
          catchtouchend="onTouchEnd"
          data-id="{{item.id}}"
        >
          <image src="{{item.path}}" style="width:100%; height:100%; display:block;" mode="scaleToFill"></image>
          
          <view class="delete-handle" catchtouchstart="deleteElement" data-id="{{item.id}}" wx:if="{{activeId === item.id}}">×</view>
          <view class="transform-handle" catchtouchstart="onTransformStart" catchtouchmove="onTransformMove" catchtouchend="onTransformEnd" data-id="{{item.id}}" wx:if="{{activeId === item.id}}">⤡</view>
        </view>
      </block>
    </view>
  </view>

  <canvas type="2d" id="exportCanvas" style="position: fixed; left: -9999px; top: 0; width: {{rawWidth}}px; height: {{rawHeight}}px;"></canvas>

  <view class="tab-header" wx:if="{{imagePath}}">
    <view class="tab-item {{currentTab === 'text' ? 'active' : ''}}" bindtap="switchTab" data-tab="text">文字</view>
    <view class="tab-item {{currentTab === 'sticker' ? 'active' : ''}}" bindtap="switchTab" data-tab="sticker">贴纸</view>
    <view class="tab-item {{currentTab === 'image' ? 'active' : ''}}" bindtap="switchTab" data-tab="image">图片</view>
  </view>

  <view class="card no-top-radius" wx:if="{{imagePath && currentTab === 'text'}}">
    <view class="add-text-btn" bindtap="addNewText">
      ➕ 添加新文字
    </view>

    <block wx:if="{{activeId}}">
      <view class="input-row">
        <input class="text-input" value="{{tempText}}" bindinput="onTextInput" placeholder="在此输入..."/>
      </view>
      <view class="style-row">
        <text class="style-label">字号</text>
        <slider class="style-slider" min="20" max="150" value="{{tempFontSize}}" bindchange="onFontSizeChange" activeColor="#6366f1" block-size="20"/>
      </view>
      <view class="style-row">
        <text class="style-label">字色</text>
        <scroll-view scroll-x class="color-scroll" enable-flex>
          <view class="color-list">
            <view class="color-item" wx:for="{{colorList}}" wx:key="color" style="background: {{item.color}};" bindtap="selectColor" data-color="{{item.color}}">
              <view wx:if="{{tempColor === item.color}}" class="check-mark {{(item.color==='#ffffff') ? 'dark-check' : ''}}">✓</view>
            </view>
          </view>
        </scroll-view>
      </view>
      
      <view class="style-row">
        <text class="style-label">背景</text>
        <scroll-view scroll-x class="color-scroll" enable-flex>
          <view class="color-list">
            <view class="color-item {{item.color === 'transparent' ? 'transparent-bg' : ''}}" wx:for="{{bgColorList}}" wx:key="color" style="background: {{item.color}};" bindtap="selectBgColor" data-color="{{item.color}}">
              <view wx:if="{{tempBgColor === item.color}}" class="check-mark {{(item.color==='#ffffff' || item.color==='transparent' || item.color==='rgba(255,255,255,0.7)') ? 'dark-check' : ''}}">✓</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="style-row">
        <text class="style-label">描边</text>
        <switch checked="{{tempStroke}}" color="#6366f1" bindchange="onStrokeChange"/>
      </view>
    </block>
  </view>

  <view class="card no-top-radius" wx:if="{{imagePath && currentTab === 'sticker'}}">
    <view class="sticker-cate-tabs">
        <view wx:for="{{stickerTabs}}" wx:key="*this" class="cate-item {{currentStickerTab === index ? 'active' : ''}}" bindtap="switchStickerTab" data-idx="{{index}}">{{item}}</view>
    </view>
    
    <scroll-view scroll-y class="sticker-grid-scroll" enable-flex>
        <view class="sticker-grid">
            <view class="sticker-box" wx:for="{{currentStickerList}}" wx:key="*this" bindtap="selectSticker" data-content="{{item}}">
              <text class="sticker-emoji">{{item}}</text>
            </view>
        </view>
    </scroll-view>

    <view class="control-panel" wx:if="{{activeId}}">
      <view class="style-row">
        <text class="style-label">大小</text>
        <slider class="style-slider" min="40" max="300" value="{{tempStickerSize}}" bindchange="onStickerSizeChange" activeColor="#6366f1" block-size="20"/>
      </view>
    </view>
  </view>

  <view class="card no-top-radius" wx:if="{{imagePath && currentTab === 'image'}}">
    <view class="add-text-btn" bindtap="addImageLayer">
      📸 导入相册图片
    </view>
    <view class="empty-tip">提示：选中图片后，拖动右下角手柄可缩放与旋转</view>
  </view>

  <view class="ad-container" style="padding: 20rpx 0;">
   <ad unit-id="{{bannerUnitId}}" binderror="onAdError"></ad>
  </view>

  <view class="bottom-bar" wx:if="{{imagePath}}">
    <view class="btn-group" style="display: flex; gap: 20rpx; width: 100%;">
        <button class="btn-icon" bindtap="chooseImage">🔄</button>
        <button class="btn-secondary" bindtap="resetAll">清空</button>
        <button class="btn-primary" bindtap="saveImage">保存</button>
    </view>
  </view>
  
  <view style="height: 180rpx;" wx:if="{{imagePath}}"></view>
</view>