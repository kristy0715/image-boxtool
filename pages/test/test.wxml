<view class="container">
  <view class="header">
    <text class="title">沙盒测试台</text>
    <text class="subtitle">用于检验新账户的接口白名单鉴权拦截</text>
  </view>
  
  <view class="config-box">
    <view class="input-group">
      <text class="label">环境 (Base URL)</text>
      <input class="input" value="{{baseUrl}}" bindinput="onBaseUrlInput" />
    </view>
    <view class="input-group">
      <text class="label">秘钥 (API Key)</text>
      <input class="input key-input" value="{{apiKey}}" bindinput="onApiKeyInput" placeholder="请输入你要测试的 sk-..." />
    </view>
  </view>

  <view class="grid-title">点击发起测试请求</view>
  <view class="btn-grid">
    <view class="test-btn btn-info" bindtap="testUserInfo">账户查询 (/api/user/info)</view>
    <view class="test-btn btn-action" bindtap="testRemoveBg">万物抠图 (/api/remove-bg)</view>
    <view class="test-btn btn-action" bindtap="testIdPhoto">AI证件照 (/api/idphoto)</view>
    <view class="test-btn btn-action" bindtap="testRemoveWatermark">去水印 (/api/remove-watermark)</view>
    <view class="test-btn btn-action" bindtap="testHdRestore">高清修复 (/api/hd-restore)</view>
    <view class="test-btn btn-action" bindtap="testParseVideo">短视频解析 (/api/parse-video)</view>
  </view>

  <view class="log-header">
    <text>请求日志 (Console)</text>
    <text class="clear-btn" bindtap="clearLogs">清空</text>
  </view>
  
  <scroll-view class="log-box" scroll-y="true" scroll-into-view="{{lastLogId}}">
    <block wx:for="{{logs}}" wx:key="index">
      <view class="log-item {{item.type}}" id="log-{{index}}">
        <view class="log-time">[{{item.time}}]</view>
        <view class="log-msg">{{item.msg}}</view>
      </view>
    </block>
    <view class="empty-log" wx:if="{{logs.length === 0}}">暂无日志，请点击上方按钮发起请求</view>
  </scroll-view>
</view>