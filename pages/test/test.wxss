page { background: #f8f9fa; font-family: monospace; }
.container { padding: 30rpx; padding-bottom: env(safe-area-inset-bottom); height: 100vh; display: flex; flex-direction: column; box-sizing: border-box; }

.header { margin-bottom: 30rpx; }
.title { display: block; font-size: 36rpx; font-weight: bold; color: #1e293b; }
.subtitle { font-size: 24rpx; color: #64748b; }

.config-box { background: #fff; padding: 24rpx; border-radius: 16rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); margin-bottom: 30rpx; }
.input-group { margin-bottom: 20rpx; }
.input-group:last-child { margin-bottom: 0; }
.label { font-size: 24rpx; color: #475569; font-weight: bold; margin-bottom: 8rpx; display: block; }
.input { background: #f1f5f9; height: 72rpx; border-radius: 8rpx; padding: 0 20rpx; font-size: 26rpx; color: #0f172a; }
.key-input { color: #059669; font-weight: bold; }

.grid-title { font-size: 26rpx; font-weight: bold; color: #334155; margin-bottom: 16rpx; }
.btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 30rpx; }
.test-btn { height: 70rpx; display: flex; align-items: center; justify-content: center; border-radius: 12rpx; font-size: 24rpx; font-weight: bold; transition: 0.1s; }
.test-btn:active { transform: scale(0.96); opacity: 0.9; }
.btn-info { background: #e0e7ff; color: #4f46e5; border: 1px solid #c7d2fe; }
.btn-action { background: #fff; color: #334155; border: 1px solid #cbd5e1; box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.02); }

.log-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; font-size: 26rpx; font-weight: bold; color: #334155; }
.clear-btn { color: #ef4444; font-size: 24rpx; cursor: pointer; padding: 10rpx; }

.log-box { flex: 1; background: #1e293b; border-radius: 16rpx; padding: 20rpx; overflow-y: auto; box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,0.2); }
.empty-log { color: #475569; font-size: 24rpx; text-align: center; margin-top: 40rpx; }
.log-item { margin-bottom: 16rpx; font-size: 22rpx; line-height: 1.5; word-break: break-all; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 16rpx; }
.log-item:last-child { border-bottom: none; margin-bottom: 0; }
.log-time { color: #94a3b8; margin-bottom: 4rpx; }
.log-msg { color: #e2e8f0; }

.type-info .log-msg { color: #38bdf8; }
.type-success .log-msg { color: #34d399; }
.type-error .log-msg { color: #f87171; font-weight: bold; }
.type-warning .log-msg { color: #fbbf24; }