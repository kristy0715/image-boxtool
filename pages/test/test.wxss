page { background-color: #f7f8fa; padding-bottom: 180rpx; }
.container { padding: 20rpx 30rpx; }

.header-tip { text-align: center; color: #666; font-size: 26rpx; margin-bottom: 20rpx; }

.card { background: #fff; border-radius: 24rpx; padding: 20rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }

/* 上传区域 */
.upload-area { 
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 400rpx; background: #f8fafc; border-radius: 16rpx; border: 2rpx dashed #cbd5e1;
}
.upload-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.upload-text { color: #64748b; font-size: 28rpx; }

/* 画布容器 */
.canvas-container { 
  position: relative; overflow: hidden; border-radius: 12rpx; margin: 0 auto;
  /* 透明背景格 */
  background-image: linear-gradient(45deg, #eee 25%, transparent 25%, transparent 75%, #eee 75%), linear-gradient(45deg, #eee 25%, transparent 25%, transparent 75%, #eee 75%);
  background-size: 20px 20px; background-position: 0 0, 10px 10px; 
}
.move-area { width: 100%; height: 100%; }
.move-view { display: flex; align-items: center; justify-content: center; }

/* 工具栏 */
.toolbar { display: flex; justify-content: center; margin-top: 24rpx; }
.tool-group { display: flex; gap: 20rpx; background: #f1f5f9; padding: 8rpx; border-radius: 40rpx; }
.tool-btn { padding: 12rpx 30rpx; border-radius: 30rpx; font-size: 24rpx; color: #475569; transition: all 0.2s; }
.tool-btn.active-tool { background: #6366f1; color: #fff; box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3); }

.brush-settings { display: flex; align-items: center; margin-top: 24rpx; padding: 0 10rpx; }
.setting-label { font-size: 26rpx; color: #64748b; margin-right: 20rpx; }
.brush-slider { flex: 1; }

/* 底部按钮 */
.bottom-bar { 
  position: fixed; bottom: 0; left: 0; right: 0; 
  background: #fff; padding: 20rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05); display: flex; gap: 20rpx; z-index: 100; 
}
.btn-icon { width: 180rpx !important; background: #f1f5f9; color: #333; font-weight: normal; }
.btn-primary { flex: 1; background: #6366f1; color: #fff; font-weight: bold; box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3); }

.result-image { width: 100%; margin-top: 20rpx; border-radius: 12rpx; border: 2rpx solid #e2e8f0; }
.section-title { font-weight: bold; font-size: 30rpx; margin-bottom: 10rpx; }
.save-tip { text-align: center; font-size: 22rpx; color: #94a3b8; margin-top: 10rpx; }