page { background-color: #f7f7f7; padding-bottom: 60rpx; }
.container { padding: 20rpx 30rpx; }

/* 通用卡片 */
.card { background: #fff; border-radius: 16rpx; padding: 40rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); }

/* 头部积分 */
.header-card { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.card-title { display: flex; align-items: center; font-size: 28rpx; color: #666; margin-bottom: 20rpx; }
.card-title .icon { margin-right: 12rpx; font-size: 34rpx; }
.score-num { font-size: 88rpx; font-weight: bold; color: #e02020; line-height: 1; margin-bottom: 24rpx; font-family: 'DIN', sans-serif; }
.score-desc { font-size: 24rpx; color: #999; }

/* 说明部分 */
.card-header { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 30rpx; }
.info-item { display: flex; align-items: center; font-size: 26rpx; color: #666; margin-bottom: 18rpx; }
.dot { width: 8rpx; height: 8rpx; background: #e02020; border-radius: 50%; margin-right: 16rpx; }

/* 按钮 */
.refresh-btn { background: #cd1818; color: #fff; font-size: 34rpx; font-weight: 500; border-radius: 12rpx; margin: 50rpx 0; padding: 24rpx 0; width: 100%; box-shadow: 0 8rpx 20rpx rgba(205, 24, 24, 0.2); }
.btn-hover { opacity: 0.9; transform: scale(0.99); }

/* 列表部分 */
.list-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; padding-left: 10rpx; }

.record-card { 
  background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; 
  display: flex; align-items: center; justify-content: space-between;
}

.record-left { flex: 1; }
.record-score { font-size: 40rpx; font-weight: bold; color: #e02020; }
.record-score .unit { font-size: 24rpx; color: #666; font-weight: normal; margin-left: 4rpx; }

.record-center { text-align: right; margin-right: 30rpx; display: flex; flex-direction: column; align-items: flex-end;}
.record-date { font-size: 24rpx; color: #999; margin-bottom: 6rpx; }
.record-time { font-size: 20rpx; color: #ccc; }

.record-right { }
.delete-btn { 
  background: #ff4d4f; color: #fff; font-size: 24rpx; 
  padding: 12rpx 30rpx; border-radius: 8rpx; 
}
.delete-btn:active { background: #d9363e; }