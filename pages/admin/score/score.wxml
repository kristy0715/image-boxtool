<view class="container">
  <view class="card header-card">
    <view class="card-title">
      <text class="icon">🔗</text>
      <text>Shiliu 平台积分</text>
    </view>
    <view class="score-num">{{score}}</view>
    <view class="score-desc">用于基础线路图片处理</view>
  </view>

  <view class="card info-card commercial-card">
    <view class="card-header"><text class="icon">💎</text> GoodStudy AI 商业资产</view>
    <view class="asset-row">
      <view class="asset-box">
        <view class="asset-val">¥{{balance}}</view>
        <view class="asset-label">账户余额</view>
      </view>
      <view class="asset-box">
        <view class="asset-val" style="color: {{isVip ? '#6366f1' : '#ff9800'}}">
          {{isVip ? 'VIP' : '普通'}}
        </view>
        <view class="asset-label">{{isVip ? vipExpireAt + ' 到期' : '会员状态'}}</view>
      </view>
    </view>
  </view>

  <view class="card info-card">
    <view class="card-header">双平台使用说明</view>
    <view class="info-list">
      <view class="info-item"><view class="dot"></view>Shiliu 积分用于兼容旧版接口服务</view>
      <view class="info-item"><view class="dot red-dot"></view>商业余额用于最新的高性能 AI 接口</view>
    </view>
  </view>

  <button class="refresh-btn" hover-class="btn-hover" bindtap="onRefresh">同步所有平台资产</button>

  <view class="list-title">资产对账记录</view>
  <view class="record-list">
    <view class="record-card" wx:for="{{logs}}" wx:key="id">
      <view class="record-left">
        <view class="record-score">{{item.score}} <text class="unit">Shiliu积分</text></view>
        <view class="small-text">商业余额: ¥{{item.balance}}</view>
      </view>
      <view class="record-center">
        <view class="record-date">{{item.date}}</view>
        <view class="record-time">{{item.time}}</view>
      </view>
      <view class="record-right">
        <view class="delete-btn" bindtap="onDeleteLog" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>
</view>