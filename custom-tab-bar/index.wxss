.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  
  /* 🌟 核心修改：高级半透明毛玻璃效果 */
  background: rgba(255, 255, 255, 0.92); 
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
  
  /* 🌟 核心修改：加深顶部阴影，让它浮在页面上方 */
  box-shadow: 0 -6rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* 顺便把顶部分割线加深一点点 */
.tab-bar-border {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1px;
  background-color: rgba(0, 0, 0, 0.08); /* 淡淡的灰线 */
  transform: scaleY(0.5);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.tab-icon {
  width: 56rpx; /* 图标放大 (原生通常约 40rpx) */
  height: 56rpx;
  margin-bottom: 6rpx;
  transition: transform 0.2s;
}

.tab-text {
  font-size: 24rpx; /* 文字放大 (原生被锁死在 20rpx 左右) */
  color: #94a3b8;
  font-weight: 500;
  transition: color 0.2s;
}

/* 选中时的暴击动画效果 */
.tab-bar-item.active .tab-icon {
  transform: scale(1.15) translateY(-4rpx); /* 选中时图标变大且微微上浮 */
}

.tab-bar-item.active .tab-text {
  color: #6366f1; /* 你的品牌紫蓝色 */
  font-weight: bold; /* 选中时文字加粗 */
}