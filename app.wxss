/* app.wxss - 全局样式 */

/* 引入自定义字体 */
page {
  --primary-color: #6366f1;
  --primary-dark: #4f46e5;
  --primary-light: #a5b4fc;
  --secondary-color: #ec4899;
  --accent-color: #14b8a6;
  --bg-color: #f5f5f7;
  --card-bg: #ffffff;
  --text-primary: #1e293b;
  --text-secondary: #64748b;
  --text-light: #94a3b8;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
  line-height: 1.6;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f0f4ff 0%, #f5f5f7 100%);
}

/* 页面标题 */
.page-header {
  padding: 40rpx 0 32rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.page-subtitle {
  padding-left: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  border: none;
  border-radius: var(--radius-md);
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.35);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.35);
}

.btn-secondary {
  background: var(--card-bg);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-light);
  border-radius: var(--radius-md);
  padding: 26rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: var(--primary-light);
  color: #ffffff;
}

/* 图标按钮 */
.icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-radius: var(--radius-lg);
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.icon-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.icon-btn .icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.icon-btn .label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 上传区域 */
.upload-area {
  border: 4rpx dashed var(--primary-light);
  border-radius: var(--radius-lg);
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.03) 0%, rgba(236, 72, 153, 0.03) 100%);
  transition: all 0.3s ease;
}

.upload-area:active {
  border-color: var(--primary-color);
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(236, 72, 153, 0.08) 100%);
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.upload-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 12rpx;
}

/* 图片预览 */
.preview-image {
  width: 100%;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
}

/* 选项组 */
.option-group {
  margin-bottom: 32rpx;
}

.option-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  padding: 20rpx 32rpx;
  border-radius: var(--radius-md);
  background: var(--bg-color);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.option-item.active {
  background: var(--primary-color);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
}

/* 滑块 */
.slider-wrapper {
  padding: 16rpx 0;
}

.slider-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.slider-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.slider-value {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 24rpx;
}

.bottom-bar .btn-primary,
.bottom-bar .btn-secondary {
  flex: 1;
  text-align: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-light);
}

/* 加载动画 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 提示消息 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.75);
  color: #ffffff;
  padding: 24rpx 48rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  z-index: 1001;
}

/* 安全区域底部间距 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
